---
import "../styles/global.css";
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  image?: string;
  type?: string;
  schema?: object; // Prop baru untuk JSON-LD kustom
}

const {
  title,
  description = "Wadah literasi digital wong Brebes. Ruang temu alternatif untuk membaca, berdiskusi, dan bergerak bersama.",
  bodyClass = "bg-slate-200 min-h-screen font-sans antialiased text-slate-900",
  image = "/literasi-brebesan-og.jpg",
  type = "website",
  schema
} = Astro.props;

const siteUrl = Astro.site || new URL('https://literasibrebesan.my.id');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const formattedTitle = title.includes('Literasi Brebesan') ? title : `${title} - Literasi Brebesan`;

// Pastikan Image URL selalu absolute (Wajib untuk WhatsApp/FB)
let socialImageURL;
if (image && image.startsWith('http')) {
  socialImageURL = new URL(image);
} else {
  socialImageURL = new URL(image || '/literasi-brebesan-og.jpg', siteUrl);
}

// JSON-LD data terstruktur (default jika schema tidak dikirim)
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Komunitas Literasi Brebesan",
  "alternateName": "LIBES",
  "url": siteUrl,
  "description": description
};

const finalSchema = schema || defaultJsonLd;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- SEO Dasar -->
    <title>{formattedTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="komunitas literasi brebes, komunitas literasi brebesan, literasi brebesan, komunitas literasi di brebes, literasi brebes, membaca berdaya bergerak nyata, literasi digital brebes" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/literasi-brebesan.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/literasi-brebesan.png" />

    <!-- Meta Tags for Social Media Previews -->
    <meta itemprop="name" content={formattedTitle} />
    <meta itemprop="description" content={description} />
    <meta itemprop="image" content={socialImageURL.href} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={formattedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL.href} />
    <meta property="og:image:secure_url" content={socialImageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={formattedTitle} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Literasi Brebesan" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL.href} />
    <meta name="twitter:title" content={formattedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL.href} />
    <meta name="twitter:image:alt" content={formattedTitle} />
    <meta name="twitter:site" content="@libes_brebesan" />

    <!-- Additional for WhatsApp and other crawlers -->
    <meta name="image" content={socialImageURL.href} />
    <link rel="image_src" href={socialImageURL.href} />

    <!-- Font & Preconnect -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link href="https://fonts.bunny.net/css?family=plus-jakarta-sans:400,500,600,700,800&display=swap" rel="stylesheet" />

    <!-- Data Terstruktur -->
    <script type="application/ld+json" set:html={JSON.stringify(finalSchema)} />

    <ClientRouter />
    <slot name="head" />
    <style is:global>
      /* Global Progress Bar Style */
      #nprogress {
        pointer-events: none;
      }
      #nprogress .bar {
        background: #2563eb; /* blue-600 */
        position: fixed;
        z-index: 9999;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
      }
      .nprogress-pulse {
        display: block;
        position: absolute;
        right: 0px;
        width: 100px;
        height: 100%;
        box-shadow: 0 0 10px #2563eb, 0 0 5px #2563eb;
        opacity: 1.0;
        transform: rotate(3deg) translate(0px, -4px);
      }
    </style>
  </head>
  <body class={bodyClass}>
    <div id="nprogress" class="hidden"><div class="bar" role="bar"><div class="nprogress-pulse"></div></div></div>
    
    <script>
      // Logic for Global Progress Bar
      document.addEventListener('astro:before-preparation', () => {
        const nprogress = document.getElementById('nprogress');
        if (nprogress) nprogress.classList.remove('hidden');
      });

      document.addEventListener('astro:page-load', () => {
        const nprogress = document.getElementById('nprogress');
        if (nprogress) nprogress.classList.add('hidden');
      });
      
      // Handle navigation errors/cancellation
      document.addEventListener('astro:after-preparation', () => {
        // Preparation finished, but page-load hasn't fired yet. 
        // We keep it visible until page-load.
      });
    </script>
    <slot />
  </body>
</html>