---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import { sql } from "../../../../lib/db";
import RichTextEditor from "../../../../components/RichTextEditor.astro";
import TitleEditor from "../../../../components/Editor/TitleEditor";

const { id } = Astro.params;
const { user } = Astro.locals;

// Proteksi Admin
if (user?.role !== 'admin') return Astro.redirect('/user');

// Ambil data dari DB (Admin bisa edit postingan siapa saja)
const { rows } = await sql`
  SELECT p.*, pr.full_name as author_name 
  FROM posts p
  JOIN profiles pr ON p.user_id = pr.id
  WHERE p.id = ${id}
`;
const post = rows[0];

// Ambil daftar kategori untuk dropdown
const { rows: categories } = await sql`SELECT id, name FROM categories ORDER BY name ASC`;

if (!post) return Astro.redirect('/admin?error=Postingan tidak ditemukan');

const result = Astro.getActionResult(actions.updatePost);
if (result && !result.error) return Astro.redirect('/admin?success=Perubahan tulisan berhasil disimpan.');

const formatDate = (date: any) => {
  return new Date(date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
};
---

<DashboardLayout title="Edit Artikel - Admin">
  <div class="max-w-4xl mx-auto px-4 py-6 md:py-8 pb-32">
    <header class="mb-8 md:mb-10">
      <a href="/admin" class="inline-flex items-center text-[10px] font-black uppercase tracking-wider text-slate-400 hover:text-blue-600 transition-colors mb-3 md:mb-4 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Dashboard Admin / Moderasi
      </a>
      <h1 class="text-2xl md:text-5xl font-black tracking-tight text-slate-900 leading-tight">Edit Konten</h1>
      <p class="text-[10px] font-bold text-slate-400 mt-1 md:mt-2 uppercase tracking-widest leading-none">
        Penulis: {post.author_name} • {formatDate(post.created_at)}
      </p>
    </header>

    <form method="POST" action={actions.updatePost} class="space-y-8 md:space-y-12">
      <input type="hidden" name="id" value={post.id} />

      {/* 1. Area Judul & Kategori (Mimicking Output Header) */}
      <div class="space-y-4 md:space-y-6">
        <div class="group">
          <label class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2 block pl-1">Judul Artikel</label>
          <TitleEditor client:load name="title" value={post.title} placeholder="Tulis judul di sini..." />
        </div>

        {post.rejection_reason && (
          <div class="bg-amber-50 border-l-4 border-amber-400 p-4 md:p-6 rounded-r-2xl animate-in slide-in-from-left duration-500">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <div>
                <span class="text-[10px] font-black uppercase tracking-widest text-amber-700 block mb-1">Catatan Moderasi:</span>
                <p class="text-xs md:text-sm font-bold text-amber-900 leading-relaxed italic">"{post.rejection_reason}"</p>
              </div>
            </div>
          </div>
        )}

        <div class="inline-flex items-center gap-3 bg-slate-50 p-1.5 rounded-2xl border border-slate-100 shadow-sm">
          <span class="pl-3 text-[10px] font-black uppercase tracking-wider text-slate-400">Kategori:</span>
          <select name="category_id" class="bg-white px-4 py-2 border border-slate-200 rounded-xl outline-none font-bold text-slate-700 text-xs cursor-pointer focus:border-blue-500">
            <option value="">Pilih Kategori</option>
            {categories.map((cat) => (
              <option value={cat.id} selected={cat.id === post.category_id}>{cat.name}</option>
            ))}
          </select>
        </div>
      </div>

      {/* 2. Rich Text Editor (Prose-styled inside) */}
      <div class="group">
        <label class="text-[10px] font-black uppercase tracking-wider text-slate-400 mb-4 block pl-1">Isi Artikel (WYSIWYG)</label>
        <RichTextEditor name="content" value={post.content} />
      </div>

      {/* 3. Moderasi Section (Sticky Footer for Admin) */}
      <div class="fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-md border-t border-slate-200 p-4 md:p-6 z-[40]">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-end justify-between gap-6">
          <div class="flex flex-col gap-3 w-full md:flex-1">
            <label class="text-[10px] font-black uppercase tracking-wider text-slate-400">Moderasi & Feedback</label>
            <div class="flex flex-col lg:flex-row gap-4">
              <div class="flex bg-slate-100 p-1 rounded-2xl gap-1 border border-slate-200 h-fit">
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="status" value="draft" class="peer hidden" checked={post.status === 'draft'} />
                  <div class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all peer-checked:bg-white peer-checked:text-slate-900 peer-checked:shadow-sm text-slate-500 whitespace-nowrap">Draft / Tolak</div>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="status" value="pending" class="peer hidden" checked={post.status === 'pending'} />
                  <div class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all peer-checked:bg-blue-600 peer-checked:text-white peer-checked:shadow-lg text-slate-500 whitespace-nowrap">Pending</div>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="status" value="published" class="peer hidden" checked={post.status === 'published'} />
                  <div class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-wider transition-all peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:shadow-lg text-slate-500 whitespace-nowrap">Publish</div>
                </label>
              </div>
              
              <div class="flex-1">
                <textarea 
                  name="rejection_reason" 
                  rows="1" 
                  placeholder="Ketik catatan revisi baru di sini..."
                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-xs font-bold text-slate-700 outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100 transition-all resize-none"
                ></textarea>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-4 w-full md:w-auto">
             <button type="submit" class="w-full md:w-auto bg-blue-600 text-white font-black px-8 py-4 rounded-2xl hover:bg-slate-900 transition-all shadow-xl shadow-blue-100 uppercase tracking-wider text-[11px] whitespace-nowrap active:scale-95">
                Simpan Moderasi
             </button>
          </div>
        </div>
      </div>
    </form>
  </div>
</DashboardLayout>
