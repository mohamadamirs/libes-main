---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { sql } from "../../../lib/db";
import { actions } from "astro:actions";

const { user } = Astro.locals;
if (user?.role !== 'admin') return Astro.redirect('/user');

// Cek apakah sudah ada agenda LAIN yang statusnya published
const { rows: conflict } = await sql`
  SELECT title FROM agendas
  WHERE status = 'published'
  AND event_date >= CURRENT_DATE
  LIMIT 1
`;
const hasConflict = conflict.length > 0;

const result = Astro.getActionResult(actions.saveAgenda);
if (result && !result.error) {
  return Astro.redirect('/admin');
}
---

<DashboardLayout title="Buat Agenda Baru">
  <div class="max-w-3xl mx-auto pt-8 pb-20 px-4 sm:px-6">
    <header class="mb-8 md:mb-10 text-center md:text-left">
      <div class="flex items-center justify-center md:justify-start gap-2 mb-2">
         <a href="/admin" class="text-[11px] md:text-xs font-black uppercase tracking-widest text-blue-600 hover:underline">← Dasbor Admin</a>
      </div>
      <h1 class="text-3xl md:text-4xl font-black italic uppercase tracking-tighter text-slate-900">Agenda Baru</h1>
      <p class="text-xs md:text-sm font-bold text-slate-400 mt-1 uppercase tracking-widest">Literasi Brebesan</p>
    </header>

    <form method="POST" action={actions.saveAgenda} enctype="multipart/form-data" class="space-y-5 md:space-y-6 md:bg-white md:p-8 md:rounded-[2.5rem] md:shadow-sm md:border md:border-slate-100 text-left">

      <div class="group">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Judul Acara</label>
        <input type="text" name="title" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm md:text-base text-slate-900 placeholder:text-slate-300" placeholder="Misal: Diskusi Buku..." />
      </div>

      <div class="group">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Deskripsi Singkat</label>
        <textarea name="description" rows="4" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-medium text-sm md:text-base text-slate-700 placeholder:text-slate-300" placeholder="Jelaskan detail acara..."></textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
        <div class="group">
          <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Tanggal Acara</label>
          <input type="date" name="event_date" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm md:text-base text-slate-700" />
        </div>
        <div class="group">
          <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Waktu Mulai</label>
          <input type="time" name="event_time" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm md:text-base text-slate-700" />
        </div>
      </div>

      <div class="group">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Lokasi</label>
        <input type="text" name="location" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm md:text-base text-slate-700 placeholder:text-slate-300" placeholder="Cth: Kedai Kopi Sekitar, Brebes" />
      </div>

      <div class="group">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Link WhatsApp RSVP</label>
        <input type="url" name="wa_link" value="https://wa.me/628993986415" required class="w-full px-5 py-4 md:px-6 md:py-5 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm md:text-base text-slate-700" />
      </div>

      <div class="group">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Poster Kegiatan (Opsional)</label>
        <input type="file" name="poster" accept="image/*" class="w-full px-5 py-3 md:px-6 md:py-4 bg-white md:bg-slate-50 border border-slate-200 rounded-[2rem] focus:ring-4 focus:ring-blue-50 outline-none transition-all font-bold text-sm text-slate-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-[11px] file:font-black file:uppercase file:tracking-widest file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" />
      </div>

      <div class="bg-slate-50 md:bg-slate-100 p-5 md:p-6 rounded-[2rem] border border-slate-200 space-y-4">
        <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-900 text-center">Status Publikasi</label>

        <div class="flex flex-col sm:flex-row bg-white p-2 rounded-[2rem] sm:rounded-full gap-2 sm:gap-1 shadow-sm border border-slate-100">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="status" value="draft" class="peer hidden" checked id="status-draft" />
            <div class="text-center py-3 md:py-4 rounded-[1.5rem] sm:rounded-full text-[11px] md:text-[11px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-slate-100 peer-checked:text-slate-900 transition-all">Draft</div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="status" value="scheduled" class="peer hidden" id="status-scheduled" />
            <div class="text-center py-3 md:py-4 rounded-[1.5rem] sm:rounded-full text-[11px] md:text-[11px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-amber-500 peer-checked:text-white peer-checked:shadow-md transition-all">Jadwalkan</div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="status" value="published" class="peer hidden" id="status-published" />
            <div class="text-center py-3 md:py-4 rounded-[1.5rem] sm:rounded-full text-[11px] md:text-[11px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:shadow-md transition-all">Publish</div>
          </label>
        </div>

        {hasConflict && (
          <div id="conflict-alert" class="hidden p-4 bg-amber-50 border border-amber-200 rounded-2xl transition-all">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-white shrink-0 shadow-sm font-black text-sm">!</div>
              <div>
                <p class="text-xs font-bold text-amber-900 leading-tight mb-2">Agenda <span class="underline">"{conflict[0].title}"</span> sedang tayang.</p>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="override_published" id="override-checkbox" class="w-4 h-4 accent-amber-600 rounded" />
                  <span class="text-[11px] font-black uppercase tracking-wider text-slate-700">Otomatis ubah yang lama jadi Draft</span>
                </label>
              </div>
            </div>
          </div>
        )}

        <div id="publish-at-container" class="hidden pt-2 group transition-all">
          <label class="block text-[11px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Pilih Waktu Rilis Otomatis</label>
          <input type="datetime-local" name="publish_at" id="publish-at-input" class="w-full px-5 py-4 md:px-6 md:py-5 bg-white border border-amber-200 rounded-[2rem] focus:ring-4 focus:ring-amber-50 outline-none transition-all font-bold text-sm md:text-base text-slate-700" />
        </div>
      </div>

      <button type="submit" class="w-full bg-slate-900 text-white font-black py-5 md:py-6 rounded-[2rem] hover:bg-black transition-all shadow-xl shadow-slate-200 uppercase tracking-widest text-[11px] md:text-xs active:scale-95 mt-4 md:mt-8 cursor-pointer">
        Simpan Agenda
      </button>

      {result?.error && (
        <div class="mt-4 p-4 bg-rose-50 border border-rose-200 rounded-2xl">
          <p class="text-[11px] text-center text-rose-600 font-black uppercase tracking-widest">Gagal Menyimpan</p>
          <p class="text-xs text-center text-rose-700 font-bold mt-1">{result.error.message}</p>
        </div>
      )}

    </form>
  </div>
</DashboardLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const radioScheduled = document.getElementById('status-scheduled') as HTMLInputElement;
    const radioDraft = document.getElementById('status-draft') as HTMLInputElement;
    const radioPublished = document.getElementById('status-published') as HTMLInputElement;

    // Elemen Waktu Publish
    const containerTime = document.getElementById('publish-at-container');
    const inputTime = document.getElementById('publish-at-input') as HTMLInputElement;

    // Elemen Peringatan Bentrok
    const conflictAlert = document.getElementById('conflict-alert');
    const overrideCheckbox = document.getElementById('override-checkbox') as HTMLInputElement;

    function handleStatusChange() {
      // 1. Logika untuk kolom tanggal "Jadwalkan"
      if (radioScheduled?.checked) {
        containerTime?.classList.remove('hidden');
        inputTime?.setAttribute('required', 'true');
      } else {
        containerTime?.classList.add('hidden');
        if(inputTime) {
          inputTime.removeAttribute('required');
          inputTime.value = '';
        }
      }

      // 2. Logika untuk Checkbox Penimpa (Override)
      if (conflictAlert && overrideCheckbox) {
        if (radioPublished?.checked) {
          // Kalau admin milih Publish, munculkan checkbox dan otomatis centang!
          conflictAlert.classList.remove('hidden');
          overrideCheckbox.checked = true;
        } else {
          // Kalau draft/scheduled, hilangkan alert dan matikan centangnya
          conflictAlert.classList.add('hidden');
          overrideCheckbox.checked = false;
        }
      }
    }

    // Pasang pelacak aktivitas klik
    if (radioScheduled) {
      radioScheduled.addEventListener('change', handleStatusChange);
      radioDraft?.addEventListener('change', handleStatusChange);
      radioPublished?.addEventListener('change', handleStatusChange);

      // Eksekusi sekali saat pertama kali halaman dibuka
      handleStatusChange();
    }

    // Loading State
    const form = document.querySelector('form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const spinner = document.getElementById('loading-spinner');

    form?.addEventListener('submit', () => {
      submitBtn?.setAttribute('disabled', 'true');
      btnText?.classList.add('hidden');
      spinner?.classList.remove('hidden');
    });
  });
</script>d?.addEventListener('change', handleStatusChange);

