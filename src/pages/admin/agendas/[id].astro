---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { sql } from "../../../lib/db";
import { actions } from "astro:actions";
import AgendaStatusManager from "../../../components/admin/AgendaStatusManager";

const { id } = Astro.params;
const { user } = Astro.locals;
if (user?.role !== 'admin') return Astro.redirect('/user');

// Ambil data agenda yang mau diedit
const { rows } = await sql`SELECT * FROM agendas WHERE id = ${id}`;
const agenda = rows[0];
if (!agenda) return Astro.redirect('/admin');

// Cek apakah ada agenda LAIN yang statusnya published
const { rows: conflict } = await sql`
  SELECT title FROM agendas
  WHERE status = 'published'
  AND event_date >= CURRENT_DATE
  AND id != ${id}
  LIMIT 1
`;
const hasConflict = conflict.length > 0;

const result = Astro.getActionResult(actions.saveAgenda);
if (result && !result.error) return Astro.redirect('/admin');
---

<DashboardLayout title="Edit Agenda">
  <div class="max-w-3xl mx-auto pt-8 pb-20 px-4">
    <header class="mb-8">
      <a href="/admin" class="text-[11px] font-black uppercase text-blue-600">← Kembali ke Dashboard</a>
      <h1 class="text-3xl font-black uppercase text-slate-900 mt-2 leading-none">Edit Agenda</h1>
    </header>

    {hasConflict && (
      <div class="mb-8 p-5 bg-rose-50 border-2 border-rose-100 rounded-[2rem] flex items-center gap-4 overflow-hidden">
        <div class="w-10 h-10 bg-rose-500 rounded-full flex items-center justify-center text-white shrink-0 shadow-lg shadow-rose-200">!</div>
        <div class="min-w-0 flex-1">
          <p class="text-[11px] font-black uppercase text-rose-500 tracking-widest">Peringatan Penting</p>
          <p class="text-xs font-bold text-rose-900 leading-tight break-words">Agenda <span class="underline">"{conflict[0].title}"</span> sedang tayang. Ubah agenda tersebut ke Draft jika ingin menerbitkan yang ini.</p>
        </div>
      </div>
    )}

    <form method="POST" action={actions.saveAgenda} enctype="multipart/form-data" class="space-y-6 md:bg-white md:p-8 md:rounded-[2.5rem] md:border md:border-slate-100">
      <input type="hidden" name="id" value={agenda.id} />

      <div class="group">
        <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Judul Acara</label>
        <input type="text" name="title" value={agenda.title} required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] outline-none font-bold text-slate-900" />
      </div>

      <div class="group">
        <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Deskripsi</label>
        <textarea name="description" rows="4" required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] outline-none font-medium text-slate-700">{agenda.description}</textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="group">
          <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Tanggal</label>
          <input type="date" name="event_date" value={agenda.event_date.toISOString().split('T')[0]} required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] font-bold text-slate-700" />
        </div>
        <div class="group">
          <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Waktu Mulai</label>
          <input type="time" name="event_time" value={agenda.event_time} required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] font-bold text-slate-700" />
        </div>
      </div>

      <div class="group">
        <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Lokasi</label>
        <input type="text" name="location" value={agenda.location} required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] font-bold text-slate-700" />
      </div>

      <div class="group">
        <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">Poster (Kosongkan jika tak diubah)</label>
        <input type="file" name="poster" accept="image/*" class="w-full px-6 py-4 bg-white border border-slate-200 rounded-[2rem] text-xs font-bold" />
      </div>

      <div class="group">
        <label class="block text-[11px] font-black uppercase text-slate-400 mb-2">WhatsApp RSVP</label>
        <input type="url" name="wa_link" value={agenda.wa_link} required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-[2rem] font-bold text-slate-700" />
      </div>

      <AgendaStatusManager 
        client:load 
        initialStatus={agenda.status} 
        initialPublishAt={agenda.publish_at} 
      />

      <button type="submit" class="w-full bg-slate-900 text-white font-black py-6 rounded-[2rem] uppercase tracking-widest text-[11px] shadow-xl shadow-slate-200">Simpan Perubahan</button>

      {result?.error && (
        <p class="text-[11px] font-black text-rose-600 bg-rose-50 p-4 rounded-2xl text-center uppercase tracking-widest">{result.error.message}</p>
      )}
    </form>
  </div>
</DashboardLayout>