---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { sql } from "../../../../lib/db";
import { actions } from "astro:actions";
import UserRoleManager from "../../../../components/admin/UserRoleManager";

const { id } = Astro.params;
const { user: currentUser } = Astro.locals;

// Proteksi Admin
if (currentUser?.role !== 'admin') return Astro.redirect('/user');

// Ambil data user
const { rows } = await sql`
  SELECT u.id, u.email, p.full_name, p.role
  FROM users u
  JOIN profiles p ON u.id = p.id
  WHERE u.id = ${id}
`;
const userToEdit = rows[0];

if (!userToEdit) return Astro.redirect('/admin?tab=users&error=User tidak ditemukan');

const result = Astro.getActionResult(actions.updateUser);
if (result && !result.error) return Astro.redirect('/admin?tab=users&success=User berhasil diperbarui');
---

<DashboardLayout title="Edit User - Admin">
  <div class="max-w-3xl mx-auto px-4 py-8 pb-24">
    <header class="mb-10">
      <a href="/admin?tab=users" class="inline-flex items-center text-[10px] font-black uppercase tracking-wider text-slate-400 hover:text-blue-600 transition-colors mb-4 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali ke Daftar User
      </a>
      <h1 class="text-3xl md:text-4xl font-black uppercase text-slate-900 leading-none">Edit Pengguna</h1>
      <p class="text-xs font-bold text-slate-400 mt-2 uppercase tracking-widest">ID: {userToEdit.id}</p>
    </header>

    <form method="POST" action={actions.updateUser} class="space-y-6 bg-white p-6 md:p-10 rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100">
      <input type="hidden" name="id" value={userToEdit.id} />

      <!-- Full Name -->
      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Nama Lengkap</label>
        <input 
          type="text" 
          name="fullName" 
          value={userToEdit.full_name}
          required 
          class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-bold text-slate-900" 
        />
      </div>

      <!-- Email -->
      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Alamat Email</label>
        <input 
          type="email" 
          name="email" 
          value={userToEdit.email}
          required 
          class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-bold text-slate-900" 
        />
      </div>

      <!-- Role Selection Island -->
      <UserRoleManager client:load initialRole={userToEdit.role} />

      <!-- Change Password (Optional) -->
      <div class="pt-4 border-t border-slate-100">
        <div class="group">
          <label class="block text-[10px] font-black uppercase tracking-wider text-slate-400 mb-2 group-focus-within:text-blue-600 transition-colors">Ganti Password (Kosongkan jika tak diubah)</label>
          <input 
            type="password" 
            name="password" 
            placeholder="Minimal 6 karakter"
            class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 transition-all font-bold text-slate-900" 
          />
        </div>
      </div>

      <div class="pt-6">
        <button type="submit" class="w-full bg-slate-900 text-white font-black py-5 rounded-2xl hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 uppercase tracking-widest text-[11px] active:scale-95">
          Simpan Perubahan User
        </button>
      </div>

      {result?.error && (
        <p class="mt-4 text-[10px] font-bold text-red-600 bg-red-50 p-4 rounded-xl text-center uppercase">{result.error.message}</p>
      )}
    </form>
  </div>
</DashboardLayout>
