---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { sql } from "../../lib/db";
import { actions } from "astro:actions";

const { user } = Astro.locals;

// Proteksi halaman admin
if (user?.role !== 'admin') return Astro.redirect('/user');

// Ambil semua data artikel
const { rows: allPosts } = await sql`
  SELECT p.*, pr.full_name as author
  FROM posts p
  JOIN profiles pr ON p.user_id = pr.id
  ORDER BY p.created_at DESC
`;

// Pisahkan berdasarkan status
const pendingPosts = allPosts.filter(p => p.status === 'pending');
const publishedPosts = allPosts.filter(p => p.status === 'published');

const stats = {
  pending: pendingPosts.length,
  published: publishedPosts.length,
  total: allPosts.length
};

const formatDate = (date: any) => {
  return new Date(date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
};
---

<DashboardLayout title="Dasbor Admin">
  <div class="pt-6 pb-24 px-4 max-w-lg mx-auto">

    <header class="mb-6">
      <h1 class="text-2xl font-bold text-slate-900">Dasbor Admin</h1>
      <p class="text-sm text-slate-500">Kelola semua artikel di sini.</p>
    </header>

    <div class="grid grid-cols-3 gap-2 mb-8">
      <div class="bg-blue-50 border border-blue-100 p-3 rounded-xl text-center">
        <span class="block text-xl font-bold text-blue-700">{stats.pending}</span>
        <span class="text-[10px] text-blue-600 font-medium uppercase tracking-wider">Menunggu</span>
      </div>
      <div class="bg-green-50 border border-green-100 p-3 rounded-xl text-center">
        <span class="block text-xl font-bold text-green-700">{stats.published}</span>
        <span class="text-[10px] text-green-600 font-medium uppercase tracking-wider">Terbit</span>
      </div>
      <div class="bg-slate-50 border border-slate-200 p-3 rounded-xl text-center">
        <span class="block text-xl font-bold text-slate-700">{stats.total}</span>
        <span class="text-[10px] text-slate-500 font-medium uppercase tracking-wider">Total</span>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        Menunggu Persetujuan
      </h2>

      <div class="flex flex-col gap-3">
        {pendingPosts.length === 0 ? (
          <div class="text-center p-6 bg-slate-50 rounded-xl border border-slate-200">
            <p class="text-xs text-slate-500">Tidak ada artikel baru.</p>
          </div>
        ) : (
          pendingPosts.map(post => (
            <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
              <h3 class="text-sm font-bold text-slate-900 line-clamp-2 leading-tight mb-1">{post.title}</h3>
              <p class="text-[10px] text-slate-500 mb-4">{post.author} • {formatDate(post.created_at)}</p>

              <div class="grid grid-cols-3 gap-2">
                <a href={`/admin/posts/${post.id}`} class="text-center py-2.5 bg-slate-100 text-slate-700 text-[10px] font-bold rounded-lg active:bg-slate-200">
                  BACA
                </a>
                <form method="POST" action={actions.approvePost} class="m-0">
                  <input type="hidden" name="id" value={post.id} />
                  <button type="submit" class="w-full text-center py-2.5 bg-blue-600 text-white text-[10px] font-bold rounded-lg active:bg-blue-700">
                    TERIMA
                  </button>
                </form>
                <form method="POST" action={actions.deletePost} class="m-0" onsubmit="return confirm('Hapus artikel ini selamanya?')">
                  <input type="hidden" name="id" value={post.id} />
                  <button type="submit" class="w-full text-center py-2.5 bg-red-50 text-red-600 border border-red-100 text-[10px] font-bold rounded-lg active:bg-red-100">
                    TOLAK
                  </button>
                </form>
              </div>
            </div>
          ))
        )}
      </div>
    </div>

    <div>
      <h2 class="text-sm font-bold text-slate-800 mb-3 flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-slate-400"></span>
        Telah Terbit
      </h2>

      <div class="flex flex-col gap-2">
        {publishedPosts.length === 0 ? (
          <div class="text-center p-6 bg-slate-50 rounded-xl border border-slate-200">
            <p class="text-xs text-slate-500">Belum ada artikel yang diterbitkan.</p>
          </div>
        ) : (
          publishedPosts.map(post => (
            <div class="bg-white p-3 rounded-xl border border-slate-200 flex justify-between items-center gap-3">
              <div class="min-w-0 flex-1">
                <h3 class="text-xs font-bold text-slate-900 truncate">{post.title}</h3>
                <p class="text-[9px] text-slate-500 mt-0.5">{post.author}</p>
              </div>

              <div class="flex gap-1.5 shrink-0">
                <a href={`/admin/posts/${post.id}`} class="px-3 py-2 bg-slate-100 text-slate-600 text-[9px] font-bold rounded-md">BACA</a>
                <form method="POST" action={actions.deletePost} class="m-0" onsubmit="return confirm('Hapus artikel yang sudah terbit ini?')">
                  <input type="hidden" name="id" value={post.id} />
                  <button type="submit" class="px-3 py-2 bg-red-50 text-red-600 text-[9px] font-bold rounded-md">HAPUS</button>
                </form>
              </div>
            </div>
          ))
        )}
      </div>
    </div>

  </div>
</DashboardLayout>