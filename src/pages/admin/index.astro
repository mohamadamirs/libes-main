---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { sql } from "../../lib/db";
import { actions } from "astro:actions";
import Pagination from "../../components/Pagination.astro";

// Proteksi Admin
const { user } = Astro.locals;
if (user?.role !== 'admin') return Astro.redirect('/user');

// --- STATISTIK ARTIKEL (Optimasi Query) ---
const { rows: statsRows } = await sql`
  SELECT 
    COUNT(*) as total,
    SUM(CASE WHEN status = 'pending' THEN 1 ELSE 0 END) as pending,
    SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END) as published
  FROM posts
`;
const stats = {
  pending: parseInt(statsRows[0]?.pending || '0'),
  published: parseInt(statsRows[0]?.published || '0'),
  total: parseInt(statsRows[0]?.total || '0')
};

// --- PAGINATION ARTIKEL MENUNGGU ---
const pPage = parseInt(Astro.url.searchParams.get('pPage') || '1');
const pLimit = 5;
const pOffset = (pPage - 1) * pLimit;
const pTotalPages = Math.ceil(stats.pending / pLimit);

const { rows: pendingPosts } = await sql`
  SELECT p.*, pr.full_name as author, c.name as category
  FROM posts p
  JOIN profiles pr ON p.user_id = pr.id
  LEFT JOIN categories c ON p.category_id = c.id
  WHERE p.status = 'pending'
  ORDER BY p.created_at ASC
  LIMIT ${pLimit} OFFSET ${pOffset}
`;

// --- PAGINATION AGENDA ---
const aPage = parseInt(Astro.url.searchParams.get('aPage') || '1');
const aLimit = 5;
const aOffset = (aPage - 1) * aLimit;

const { rows: agendaCountRows } = await sql`SELECT COUNT(*) as total FROM agendas`;
const totalAgendas = parseInt(agendaCountRows[0]?.total || '0');
const aTotalPages = Math.ceil(totalAgendas / aLimit);

const { rows: agendas } = await sql`
  SELECT id, title, event_date, status
  FROM agendas
  ORDER BY created_at DESC
  LIMIT ${aLimit} OFFSET ${aOffset}
`;

const formatDate = (date: any) => {
  return new Date(date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
};
---

<DashboardLayout title="Dasbor Admin">
  <div class="pb-24 px-4 md:px-8 max-w-6xl mx-auto">

    <header class="mb-6 md:mb-10 text-center md:text-left">
      <h1 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight uppercase">Dashboard Admin</h1>
      <p class="text-xs md:text-sm text-slate-500 mt-1 uppercase tracking-widest font-bold">Kelola artikel dan agenda komunitas</p>
    </header>

    <div class="grid grid-cols-3 gap-2 md:gap-4 mb-8 md:mb-12">
      <div class="bg-blue-50 border border-blue-100 p-3 md:p-5 rounded-2xl text-center shadow-sm">
        <span class="block text-xl md:text-3xl font-black text-blue-700">{stats.pending}</span>
        <span class="text-[11px] md:text-[11px] text-blue-600 font-bold uppercase tracking-widest mt-1 block">Menunggu</span>
      </div>
      <div class="bg-green-50 border border-green-100 p-3 md:p-5 rounded-2xl text-center shadow-sm">
        <span class="block text-xl md:text-3xl font-black text-green-700">{stats.published}</span>
        <span class="text-[11px] md:text-[11px] text-green-600 font-bold uppercase tracking-widest mt-1 block">Terbit</span>
      </div>
      <div class="bg-slate-50 border border-slate-200 p-3 md:p-5 rounded-2xl text-center shadow-sm">
        <span class="block text-xl md:text-3xl font-black text-slate-700">{stats.total}</span>
        <span class="text-[11px] md:text-[11px] text-slate-500 font-bold uppercase tracking-widest mt-1 block">Total</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">

      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm md:text-base font-black text-slate-800 flex items-center gap-2 uppercase tracking-tight">
            <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
            Verifikasi Artikel
          </h2>
          <a href="/admin/posts/create" class="px-4 py-2 bg-blue-600 text-white text-[11px] md:text-[11px] font-black uppercase tracking-widest rounded-xl hover:bg-blue-700 transition-all shadow-md shadow-blue-100">
            + Buat Artikel
          </a>
        </div>

        <div class="flex flex-col gap-3">
          {pendingPosts.length === 0 ? (
            <div class="text-center p-8 bg-slate-50 rounded-2xl border border-slate-200 border-dashed">
              <p class="text-xs font-bold text-slate-500">Semua artikel sudah beres. ✨</p>
            </div>
          ) : (
            <>
              {pendingPosts.map(post => (
                <div class="bg-white p-4 md:p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[8px] font-black uppercase tracking-widest px-2 py-0.5 bg-blue-50 text-blue-600 rounded border border-blue-100">
                      {post.category || 'Tanpa Kategori'}
                    </span>
                  </div>
                  <h3 class="text-sm md:text-base font-bold text-slate-900 line-clamp-2 leading-tight mb-1">{post.title}</h3>
                  <p class="text-[11px] md:text-xs text-slate-500 mb-4">{post.author} • {formatDate(post.created_at)}</p>
                  <div class="grid grid-cols-3 gap-2">
                    <a href={`/admin/posts/${post.id}`} class="text-center py-2.5 bg-slate-100 text-slate-700 text-[11px] md:text-[11px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-colors">BACA</a>
                    <form method="POST" action={actions.approvePost} class="m-0">
                      <input type="hidden" name="id" value={post.id} />
                      <button type="submit" class="w-full text-center py-2.5 bg-blue-600 text-white text-[11px] md:text-[11px] font-black uppercase tracking-widest rounded-xl hover:bg-blue-700 transition-colors">TERIMA</button>
                    </form>
                    <form method="POST" action={actions.deletePost} class="m-0" onsubmit="return confirm('Hapus artikel ini selamanya?')">
                      <input type="hidden" name="id" value={post.id} />
                      <button type="submit" class="w-full text-center py-2.5 bg-red-50 text-red-600 border border-red-100 text-[11px] md:text-[11px] font-black uppercase tracking-widest rounded-xl hover:bg-red-100 transition-colors">TOLAK</button>
                    </form>
                  </div>
                </div>
              ))}
              <Pagination currentPage={pPage} totalPages={pTotalPages} paramName="pPage" />
            </>
          )}
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm md:text-base font-black text-slate-800 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span>
            Kelola Agenda
          </h2>
          <a href="/admin/agendas/create" class="px-4 py-2 bg-slate-900 text-white text-[11px] md:text-[11px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all shadow-md shadow-slate-200">
            + Buat Baru
          </a>
        </div>

        <div class="flex flex-col gap-3">
          {agendas.length === 0 ? (
            <div class="text-center p-8 bg-slate-50 rounded-2xl border border-slate-200 border-dashed">
              <p class="text-xs font-medium text-slate-500">Belum ada agenda yang dibuat.</p>
            </div>
          ) : (
            <>
              {agendas.map(agenda => (
                <div class="bg-white p-4 md:p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col sm:flex-row justify-between sm:items-center gap-4 hover:shadow-md transition-shadow">
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <h3 class="text-xs md:text-sm font-bold text-slate-900 truncate">{agenda.title}</h3>
                      <span class={`px-2 py-0.5 rounded-md text-[8px] font-black uppercase tracking-widest ${
                        agenda.status === 'published' ? 'bg-green-50 text-green-600 border border-green-100' :
                        agenda.status === 'scheduled' ? 'bg-amber-50 text-amber-600 border border-amber-100' : 'bg-slate-100 text-slate-500 border border-slate-200'
                      }`}>
                        {agenda.status}
                      </span>
                    </div>
                    <p class="text-[11px] md:text-xs font-medium text-slate-500">Aksi: {formatDate(agenda.event_date)}</p>
                  </div>

                  <div class="flex gap-2 shrink-0">
                    <a href={`/admin/agendas/${agenda.id}`} class="flex-1 sm:flex-none text-center px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[11px] font-black tracking-widest rounded-xl transition-colors">EDIT</a>
                    <form method="POST" action={actions.deleteAgenda} class="flex-1 sm:flex-none m-0" onsubmit="return confirm('Hapus agenda ini selamanya?')">
                      <input type="hidden" name="id" value={agenda.id} />
                      <button type="submit" class="w-full text-center px-4 py-2.5 bg-red-50 hover:bg-red-100 text-red-600 text-[11px] font-black tracking-widest rounded-xl transition-colors">HAPUS</button>
                    </form>
                  </div>
                </div>
              ))}
              <Pagination currentPage={aPage} totalPages={aTotalPages} paramName="aPage" />
            </>
          )}
        </div>
      </div>

    </div>
  </div>
</DashboardLayout>