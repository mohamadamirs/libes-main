---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { sql } from "../../lib/db";
import { actions } from "astro:actions";
import Pagination from "../../components/Pagination.astro";
import ArticleCard from "../../components/admin/ArticleCard";
import UserCard from "../../components/admin/UserCard";

// Proteksi Admin
const { user } = Astro.locals;
if (user?.role !== 'admin') return Astro.redirect('/user');

// 1. Ambil Tab Aktif (Default: articles)
const activeTab = Astro.url.searchParams.get('tab') || 'articles';

// 2. Inisialisasi Variabel Data
let displayData = [];
let stats = { label1: '', val1: 0, label2: '', val2: 0, label3: '', val3: 0, color: 'blue' };
let totalPages = 0;
const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 6;
const offset = (currentPage - 1) * limit;

// 3. Logika Dinamis per Tab
if (activeTab === 'articles') {
  // Query Stats Artikel
  const { rows: s } = await sql`
    SELECT 
      COUNT(*) as total,
      SUM(CASE WHEN status = 'pending' THEN 1 ELSE 0 END) as pending,
      SUM(CASE WHEN status = 'published' THEN 1 ELSE 0 END) as published
    FROM posts
  `;
  stats = {
    label1: 'Menunggu', val1: parseInt(s[0]?.pending || '0'),
    label2: 'Terbit', val2: parseInt(s[0]?.published || '0'),
    label3: 'Total', val3: parseInt(s[0]?.total || '0'),
    color: 'blue'
  };

  // Query Data Artikel
  const { rows } = await sql`
    SELECT p.*, pr.full_name as author, c.name as category
    FROM posts p
    JOIN profiles pr ON p.user_id = pr.id
    LEFT JOIN categories c ON p.category_id = c.id
    ORDER BY p.created_at DESC
    LIMIT ${limit} OFFSET ${offset}
  `;
  displayData = rows;
  totalPages = Math.ceil(stats.val3 / limit);

} else if (activeTab === 'agendas') {
  // Query Stats Agenda
  const { rows: s } = await sql`
    SELECT 
      COUNT(*) as total,
      SUM(CASE WHEN event_date >= CURRENT_DATE THEN 1 ELSE 0 END) as upcoming,
      SUM(CASE WHEN event_date < CURRENT_DATE THEN 1 ELSE 0 END) as past
    FROM agendas
  `;
  stats = {
    label1: 'Mendatang', val1: parseInt(s[0]?.upcoming || '0'),
    label2: 'Selesai', val2: parseInt(s[0]?.past || '0'),
    label3: 'Total', val3: parseInt(s[0]?.total || '0'),
    color: 'amber'
  };

  // Query Data Agenda
  const { rows } = await sql`
    SELECT * FROM agendas
    ORDER BY event_date DESC
    LIMIT ${limit} OFFSET ${offset}
  `;
  displayData = rows;
  totalPages = Math.ceil(stats.val3 / limit);

} else if (activeTab === 'users') {
  // Query Stats User
  const { rows: s } = await sql`
    SELECT 
      COUNT(*) as total,
      SUM(CASE WHEN role = 'admin' THEN 1 ELSE 0 END) as admins,
      SUM(CASE WHEN role = 'user' THEN 1 ELSE 0 END) as users
    FROM profiles
  `;
  stats = {
    label1: 'Admin', val1: parseInt(s[0]?.admins || '0'),
    label2: 'User', val2: parseInt(s[0]?.users || '0'),
    label3: 'Total', val3: parseInt(s[0]?.total || '0'),
    color: 'indigo'
  };

  // Query Data User
  const { rows } = await sql`
    SELECT p.*, u.email 
    FROM profiles p
    JOIN users u ON p.id = u.id
    ORDER BY p.full_name ASC
    LIMIT ${limit} OFFSET ${offset}
  `;
  displayData = rows;
  totalPages = Math.ceil(stats.val3 / limit);
} else if (activeTab === 'settings') {
  stats = {
    label1: 'Sistem', val1: 1,
    label2: 'Database', val2: 1,
    label3: 'Aktif', val3: 1,
    color: 'slate'
  };
  displayData = [{ id: 'general', title: 'Konfigurasi Umum' }];
}

const formatDate = (date: any) => {
  return new Date(date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
};

// Helper untuk URL Tab
const getTabUrl = (tab: string) => `/admin?tab=${tab}`;
---

<DashboardLayout title="Dashboard Admin">
  <div class="pb-24 px-4 md:px-8 max-w-5xl mx-auto">

    <!-- Header & Navigation Badges -->
    <header class="mb-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
        <div>
          <h1 class="text-3xl font-black text-slate-900 tracking-tighter leading-none">Dashboard Admin</h1>
          <p class="text-xs font-bold text-slate-500 mt-2 tracking-wider">Sistem Manajemen Literasi Brebesan</p>
        </div>
        
        <nav class="flex p-1 bg-slate-100 rounded-2xl md:rounded-full w-fit border border-slate-200">
          {[
            { id: 'articles', label: 'Artikel' },
            { id: 'agendas', label: 'Agenda' },
            { id: 'users', label: 'User' },
            { id: 'settings', label: 'Settings' }
          ].map((tab) => (
            <a 
              href={getTabUrl(tab.id)} 
              class={`relative px-5 py-2.5 rounded-xl md:rounded-full text-[10px] font-black tracking-wider transition-colors duration-300 z-10 ${activeTab === tab.id ? 'text-white' : 'text-slate-500 hover:text-slate-900'}`}
            >
              {activeTab === tab.id && (
                <div 
                  transition:name="admin-tab-indicator"
                  class="absolute inset-0 bg-blue-600 rounded-xl md:rounded-full shadow-lg shadow-blue-200 -z-10"
                ></div>
              )}
              {tab.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Dynamic Stats Cards -->
      <div class="grid grid-cols-3 gap-3 md:gap-6">
        <div class={`p-4 md:p-6 rounded-3xl border shadow-sm transition-all duration-500 ${
          activeTab === 'articles' ? 'bg-blue-50 border-blue-100' : 
          activeTab === 'agendas' ? 'bg-amber-50 border-amber-100' : 
          activeTab === 'users' ? 'bg-indigo-50 border-indigo-100' :
          'bg-slate-50 border-slate-200'
        }`}>
          <span class={`block text-2xl md:text-4xl font-black mb-1 ${
            activeTab === 'articles' ? 'text-blue-700' : 
            activeTab === 'agendas' ? 'text-amber-700' : 
            activeTab === 'users' ? 'text-indigo-700' :
            'text-slate-700'
          }`}>{stats.val1}</span>
          <span class="text-[9px] md:text-[10px] font-black text-slate-500">{stats.label1}</span>
        </div>
        
        <div class={`p-4 md:p-6 rounded-3xl border shadow-sm transition-all duration-500 ${
          activeTab === 'articles' ? 'bg-emerald-50 border-emerald-100' : 
          activeTab === 'agendas' ? 'bg-orange-50 border-orange-100' : 
          activeTab === 'users' ? 'bg-emerald-50 border-emerald-100' :
          'bg-slate-50 border-slate-200'
        }`}>
          <span class={`block text-2xl md:text-4xl font-black mb-1 ${
            activeTab === 'articles' ? 'text-emerald-700' : 
            activeTab === 'agendas' ? 'text-orange-700' : 
            activeTab === 'users' ? 'text-emerald-700' :
            'text-slate-700'
          }`}>{stats.val2}</span>
          <span class="text-[9px] md:text-[10px] font-black text-slate-500">{stats.label2}</span>
        </div>

        <div class="p-4 md:p-6 rounded-3xl bg-white border border-slate-200 shadow-sm">
          <span class="block text-2xl md:text-4xl font-black text-slate-900 mb-1">{stats.val3}</span>
          <span class="text-[9px] md:text-[10px] font-black text-slate-500">{stats.label3}</span>
        </div>
      </div>
    </header>

    {/* --- MAIN CONTENT AREA --- */}
    <div class="space-y-6">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-black text-slate-800">
          Kelola {activeTab === 'articles' ? 'Artikel' : activeTab === 'agendas' ? 'Agenda' : activeTab === 'users' ? 'User' : 'Settings'}
        </h2>
        {activeTab === 'articles' && <a href="/admin/posts/create" class="text-[10px] font-black bg-blue-600 text-white px-4 py-2 rounded-xl">+ Artikel Baru</a>}
        {activeTab === 'agendas' && <a href="/admin/agendas/create" class="text-[10px] font-black bg-amber-500 text-white px-4 py-2 rounded-xl">+ Agenda Baru</a>}
        {activeTab === 'users' && <a href="/admin/users/create" class="text-[10px] font-black bg-indigo-600 text-white px-4 py-2 rounded-xl">+ User Baru</a>}
      </div>

      <div class="flex flex-col gap-3">
        {displayData.length === 0 ? (
          <div class="p-12 text-center bg-slate-50 rounded-3xl border border-dashed border-slate-300">
            <p class="text-xs font-bold text-slate-500">Data tidak ditemukan.</p>
          </div>
        ) : (
          <>
            {activeTab === 'articles' && displayData.map(post => (
              <ArticleCard 
                client:load
                post={post} 
              />
            ))}

            {activeTab === 'agendas' && displayData.map(agenda => (
              <div class="bg-white p-4 md:p-6 rounded-[1.5rem] border border-slate-200 shadow-sm hover:shadow-md transition-all">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                  {/* Kolom Kiri: Info */}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-2">
                      <h3 class="font-bold text-slate-900 truncate">{agenda.title}</h3>
                      <span class={`text-[8px] font-black uppercase tracking-widest px-2 py-0.5 rounded border ${agenda.status === 'published' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : 'bg-amber-50 text-amber-600 border-amber-100'}`}>{agenda.status}</span>
                    </div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">{formatDate(agenda.event_date)} • {agenda.location}</p>
                  </div>

                  {/* Kolom Kanan: Aksi */}
                  <div class="flex flex-wrap md:flex-nowrap items-center gap-2 shrink-0">
                    {agenda.status !== 'published' && (
                      <form method="POST" action={actions.quickPublishAgenda} class="flex-1 md:flex-none m-0">
                        <input type="hidden" name="id" value={agenda.id} />
                        <button type="submit" class="w-full px-4 py-2.5 bg-emerald-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-emerald-700 transition-all shadow-md shadow-emerald-100">Publish</button>
                      </form>
                    )}

                    <a href={`/admin/agendas/${agenda.id}`} class="flex-1 md:flex-none px-4 py-2.5 bg-slate-50 text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-all text-center">Edit</a>
                    
                    <form method="POST" action={actions.deleteAgenda} class="flex-1 md:flex-none m-0" onsubmit="return confirm('Hapus agenda ini?')">
                      <input type="hidden" name="id" value={agenda.id} />
                      <button type="submit" class="w-full px-4 py-2.5 bg-red-50 text-red-600 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-red-100 transition-all">Hapus</button>
                    </form>
                  </div>
                </div>
              </div>
            ))}

            {activeTab === 'users' && displayData.map(p => (
              <UserCard client:load user={p} />
            ))}

            {activeTab === 'settings' && (
              <div class="space-y-4">
                <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                  <h3 class="font-black text-slate-900 uppercase tracking-widest text-sm mb-4">Konfigurasi Situs</h3>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                      <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Nama Situs</p>
                      <p class="font-bold text-slate-700">Literasi Brebesan</p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                      <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Status Sistem</p>
                      <p class="font-bold text-emerald-600 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        Online / Aktif
                      </p>
                    </div>
                  </div>
                </div>

                <div class="bg-amber-50 p-6 rounded-[2rem] border border-amber-100">
                  <h3 class="font-black text-amber-900 uppercase tracking-widest text-sm mb-2">Mode Maintenance</h3>
                  <p class="text-xs text-amber-700 font-medium mb-4">Aktifkan ini jika Anda ingin menutup akses publik sementara untuk perbaikan.</p>
                  <button class="px-6 py-2 bg-amber-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl opacity-50 cursor-not-allowed">Aktifkan (Segera Hadir)</button>
                </div>
              </div>
            )}

            {activeTab !== 'settings' && (
              <div class="mt-8">
                <Pagination currentPage={currentPage} totalPages={totalPages} paramName="page" />
              </div>
            )}
          </>
        )}
      </div>
    </div>
  </div>
</DashboardLayout>
