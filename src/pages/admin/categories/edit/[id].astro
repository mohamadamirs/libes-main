---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { sql } from "../../../../lib/db";
import { actions } from "astro:actions";

const { id } = Astro.params;
const { user: currentUser } = Astro.locals;

// Proteksi Admin
if (currentUser?.role !== 'admin') return Astro.redirect('/user');

// Ambil data kategori
const { rows } = await sql`SELECT * FROM categories WHERE id = ${id}`;
const category = rows[0];

if (!category) return Astro.redirect('/admin?tab=settings&error=Kategori tidak ditemukan');

const result = Astro.getActionResult(actions.updateCategory);
if (result && !result.error) return Astro.redirect('/admin?tab=settings&success=Kategori berhasil diperbarui');
---

<DashboardLayout title="Edit Kategori - Admin">
  <div class="max-w-2xl mx-auto px-4 py-8 pb-24">
    <header class="mb-10">
      <a href="/admin?tab=settings" class="inline-flex items-center text-[10px] font-black uppercase tracking-wider text-slate-500 hover:text-blue-600 transition-colors mb-4 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Kembali ke Pengaturan
      </a>
      <h1 class="text-3xl font-black text-slate-900 leading-none uppercase tracking-tighter">Edit Kategori</h1>
      <p class="text-[10px] font-bold text-slate-500 mt-2 uppercase tracking-widest">Slug Saat Ini: {category.slug}</p>
    </header>

    <form method="POST" action={actions.updateCategory} class="space-y-6 bg-white p-8 rounded-[2rem] shadow-xl shadow-slate-200/50 border border-slate-100">
      <input type="hidden" name="id" value={category.id} />

      <div>
        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-500 mb-2 ml-1">Nama Kategori</label>
        <input 
          type="text" 
          name="name" 
          value={category.name}
          required 
          class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 focus:bg-white transition-all font-bold text-slate-900" 
        />
      </div>

      <div>
        <label class="block text-[10px] font-black uppercase tracking-wider text-slate-500 mb-2 ml-1">Deskripsi (Opsional)</label>
        <textarea 
          name="description" 
          rows="3"
          class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-blue-600 focus:bg-white transition-all font-bold text-slate-900"
        >{category.description}</textarea>
      </div>

      <div class="pt-4">
        <button type="submit" class="w-full bg-blue-600 text-white font-black py-4 rounded-2xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-100 uppercase tracking-widest text-[11px]">
          Simpan Perubahan
        </button>
      </div>

      {result?.error && (
        <p class="mt-4 text-[10px] font-bold text-red-600 bg-red-50 p-4 rounded-xl text-center uppercase">{result.error.message}</p>
      )}
    </form>
  </div>
</DashboardLayout>
