---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { actions } from "astro:actions";
import { sql } from "../../../lib/db";
import RichTextEditor from "../../../components/RichTextEditor.astro";

const { user } = Astro.locals;

const result = Astro.getActionResult(actions.createPost);
if (result && !result.error) return Astro.redirect('/user?success=Tulisan berhasil disimpan! Tunggu review admin ya.');

// Ambil daftar kategori untuk dropdown
const { rows: categories } = await sql`SELECT id, name FROM categories ORDER BY name ASC`;
---

<DashboardLayout title="Tulis Cerita">
  <div class="max-w-4xl mx-auto px-4 py-6 md:py-8">
    <header class="mb-6 md:mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4 md:gap-6">
      <div>
        <a href="/user" class="inline-flex items-center text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 hover:text-blue-600 transition-colors mb-3 md:mb-4 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Kembali ke Dashboard
        </a>
        <h1 class="text-2xl md:text-4xl font-black uppercase tracking-tighter text-slate-900 leading-none">Mulai Menulis</h1>
        <p class="text-[10px] md:text-sm font-bold text-slate-400 mt-2 md:mt-3 uppercase tracking-widest">Tuangkan gagasan dan ceritamu untuk dunia</p>
      </div>
    </header>

    <form method="POST" action={actions.createPost} class="space-y-6 md:space-y-8 bg-white p-5 md:p-10 rounded-2xl md:rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100">
      <!-- Title Input -->
      <div class="group">
        <label class="flex items-center gap-2 text-[10px] md:text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 md:mb-3 group-focus-within:text-blue-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Judul Tulisan
        </label>
        <input 
          type="text" 
          name="title" 
          required 
          class="w-full px-0 py-3 md:py-4 bg-transparent border-b-2 border-slate-100 focus:border-blue-600 outline-none transition-all font-black text-xl md:text-3xl text-slate-900 placeholder:text-slate-200" 
          placeholder="Tulis judul yang memikat..." 
        />
      </div>

      <!-- Category Selection -->
      <div class="group">
        <label class="flex items-center gap-2 text-[10px] md:text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 md:mb-3 group-focus-within:text-blue-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          Kategori Tulisan
        </label>
        <div class="relative">
          <select name="category_id" class="w-full px-4 py-3 md:px-5 md:py-4 bg-slate-50 border border-slate-200 rounded-xl md:rounded-2xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 outline-none transition-all font-bold text-slate-700 text-xs md:text-base appearance-none cursor-pointer">
            <option value="">Pilih Kategori (Opsional)</option>
            {categories.map((cat) => (
              <option value={cat.id}>{cat.name}</option>
            ))}
          </select>
          <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>

      <!-- Content Editor -->
      <div class="group">
        <label class="flex items-center gap-2 text-[10px] md:text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2 md:mb-3 group-focus-within:text-blue-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-4 md:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
          </svg>
          Isi Cerita
        </label>
        <div class="rounded-xl md:rounded-2xl overflow-hidden border border-slate-200 focus-within:border-blue-500 focus-within:ring-4 focus-within:ring-blue-100 transition-all">
          <RichTextEditor name="content" />
        </div>
      </div>

      <!-- Action Section -->
      <div class="pt-4 md:pt-6 border-t border-slate-100 flex flex-col lg:flex-row items-center gap-4 md:gap-6">
        <div class="w-full lg:flex-1 bg-slate-50 p-1 rounded-xl md:rounded-2xl flex gap-1">
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="status" value="draft" class="peer hidden" checked />
            <div class="text-center py-2.5 md:py-3 rounded-lg md:rounded-xl text-[9px] md:text-[10px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-white peer-checked:text-slate-900 peer-checked:shadow-sm transition-all">Simpan Draft</div>
          </label>
          <label class="flex-1 cursor-pointer">
            <input type="radio" name="status" value="pending" class="peer hidden" />
            <div class="text-center py-2.5 md:py-3 rounded-lg md:rounded-xl text-[9px] md:text-[10px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:shadow-lg transition-all">Kirim / Review</div>
          </label>

          {user?.role === 'admin' && (
            <label class="flex-1 cursor-pointer">
              <input type="radio" name="status" value="published" class="peer hidden" />
              <div class="text-center py-2.5 md:py-3 rounded-lg md:rounded-xl text-[9px] md:text-[10px] font-black uppercase tracking-widest text-slate-400 peer-checked:bg-emerald-500 peer-checked:text-white peer-checked:shadow-lg transition-all">Terbitkan</div>
            </label>
          )}
        </div>

        <button type="submit" class="w-full lg:w-auto px-8 md:px-10 bg-slate-900 text-white font-black py-3.5 md:py-4 rounded-xl md:rounded-2xl hover:bg-blue-600 transition-all shadow-xl shadow-slate-200 uppercase tracking-widest text-[10px] md:text-[11px] active:scale-95 flex items-center justify-center gap-2 group">
          Simpan Tulisan
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 md:w-4 md:h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>
    </form>
  </div>
</DashboardLayout>