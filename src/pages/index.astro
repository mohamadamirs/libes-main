---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/main/Hero.astro";
import About from "../components/main/About.astro";
import Stats from "../components/main/Stats.astro";
import Agenda from "../components/main/Agenda.astro";
import LatestPosts from "../components/main/LatestPosts.astro";
import GaleriGrid from "../components/main/GaleriGrid.astro";
import Footer from "../components/Footer.astro";

// JSON-LD untuk Beranda
const homeSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Literasi Brebesan",
  "alternateName": ["LIBES", "Komunitas Literasi Brebes", "Literasi Brebes"],
  "url": "https://literasibrebesan.my.id",
  "logo": "https://literasibrebesan.my.id/literasi-brebesan.webp",
  "description": "Komunitas Literasi Brebesan adalah wadah independen di Kabupaten Brebes yang berfokus pada pengembangan budaya membaca, diskusi kritis, dan aksi sosial nyata.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Brebes",
    "addressRegion": "Jawa Tengah",
    "addressCountry": "ID"
  },
  "sameAs": [
    "https://www.instagram.com/literasibrebesan"
  ]
};
---

<Layout 
  title="Literasi Brebesan | Komunitas Literasi & Ruang Baca Gratis di Brebes" 
  description="Wadah Komunitas Literasi di Brebes. Nikmati ruang diskusi, lapak baca buku gratis, dan aksi nyata untuk merawat nalar. Selamat datang di Literasi Brebesan!"
  schema={homeSchema}
>
  <Header />
  <main>
    <Hero />
    <Stats />
    <Agenda />
    <About />
    <LatestPosts />
    <GaleriGrid />
  </main>
  <Footer />
</Layout>
