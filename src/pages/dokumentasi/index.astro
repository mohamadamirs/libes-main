---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import FolderGallery from "../../components/docs/FolderGallery";
import FileGallery from "../../components/docs/FileGallery";
import Footer from "../../components/Footer.astro";

const yearId = Astro.url.searchParams.get("yearId");
const monthId = Astro.url.searchParams.get("monthId");
const activityId = Astro.url.searchParams.get("activityId");

// View logic
let label = "Arsip Dokumentasi";
let titleAksentuasi = "momen";
let titleUtama = "Merawat";
let description = "Arsip visual perjalanan dan perjumpaan kawan-kolektif Literasi Brebesan.";

if (activityId) {
  label = "Galeri Media";
  titleUtama = "Sorot";
  titleAksentuasi = "peristiwa";
} else if (monthId) {
  label = "Daftar Kegiatan";
  titleUtama = "Jejak";
  titleAksentuasi = "langkah";
} else if (yearId) {
  label = "Pilih Bulan";
  titleUtama = "Alur";
  titleAksentuasi = "waktu";
}
---

<Layout title="Dokumentasi | Literasi Brebesan">
  <Header />

  <main class="bg-white min-h-screen pt-24 md:pt-32 pb-20">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section Header -->
      <div class="mb-12 md:mb-16 text-left">
        <div class="inline-flex items-center gap-2 bg-blue-50 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-blue-100 mb-4 md:mb-6">
          <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-blue-600 animate-pulse"></span>
          <span class="text-[11px] md:text-xs font-black uppercase tracking-widest text-blue-700 leading-none">{label}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-black text-slate-900 tracking-tight uppercase leading-tight">
          {titleUtama} <span class="text-blue-600 font-bold lowercase tracking-normal">{titleAksentuasi}</span>
        </h1>

        <p class="mt-4 md:mt-6 text-slate-500 font-medium max-w-2xl text-sm md:text-lg leading-relaxed">
          {description}
        </p>
      </div>

      <!-- BREADCRUMBS -->
      <nav class="mb-8 flex items-center gap-2 text-[10px] md:text-xs font-black uppercase tracking-widest overflow-x-auto no-scrollbar py-2">
        <a href="/dokumentasi" class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all whitespace-nowrap">Root</a>
        {yearId && (
          <>
            <span class="text-slate-300">/</span>
            <a href={`/dokumentasi?yearId=${yearId}`} class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all whitespace-nowrap">Tahun</a>
          </>
        )}
        {monthId && (
          <>
            <span class="text-slate-300">/</span>
            <a href={`/dokumentasi?yearId=${yearId}&monthId=${monthId}`} class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-lg hover:bg-blue-600 hover:text-white transition-all whitespace-nowrap">Bulan</a>
          </>
        )}
        {activityId && (
          <>
            <span class="text-slate-300">/</span>
            <span class="px-3 py-1.5 bg-blue-50 text-blue-600 rounded-lg border border-blue-100 whitespace-nowrap">Media</span>
          </>
        )}
      </nav>

      <div class="relative min-h-[400px]">
        {/* Folder Gallery */}
        {!activityId && (
          <FolderGallery
            client:load
            yearId={yearId}
            monthId={monthId}
            activityId={activityId}
          />
        )}

        {/* File Gallery */}
        {activityId && (
          <FileGallery client:visible activityId={activityId} />
        )}
      </div>

      {/* Note regarding photo removal */}
      <div class="mt-16 p-6 md:p-8 rounded-2xl md:rounded-[2.5rem] bg-amber-50 border border-amber-100/50 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center text-amber-600 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          </div>
          <div>
            <h4 class="text-sm md:text-base font-black text-amber-900 uppercase tracking-tight mb-1">Informasi Privasi</h4>
            <p class="text-amber-700/80 text-xs md:text-sm font-medium leading-relaxed max-w-xl">
              Jika ada yang merasa tidak nyaman fotonya dimasukkan ke dalam arsip dokumentasi ini, silakan hubungi admin untuk permintaan penghapusan.
            </p>
          </div>
        </div>
        <a
          href="https://wa.me/6285138228931"
          target="_blank"
          class="flex items-center gap-2 bg-amber-600 text-white px-6 py-3 rounded-xl text-[10px] md:text-xs font-black uppercase tracking-widest hover:bg-amber-700 transition-all shadow-lg shadow-amber-900/10 whitespace-nowrap"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          Hubungi Admin (WA)
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
