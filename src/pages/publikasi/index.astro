---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { sql } from "../../lib/db";

// Narik postingan yang statusnya PUBLISHED
const { rows: posts } = await sql`
  SELECT
    p.title,
    p.content,
    p.slug,
    p.updated_at,
    pr.full_name as author_name
  FROM posts p
  LEFT JOIN profiles pr ON p.user_id = pr.id
  WHERE p.status = 'published'
  ORDER BY p.updated_at DESC
`;

const truncateText = (text: string | null, length = 150) => {
  if (!text) return "Tidak ada ringkasan...";
  return text.length > length ? text.substring(0, length) + "..." : text;
};

const formatDate = (date: any) => {
  if (!date) return "";
  return new Date(date).toLocaleDateString("id-ID", {
    year: "numeric", month: "short", day: "numeric",
  });
};
---

<Layout title="Publikasi | Literasi Brebesan" description="Kumpulan tulisan dan cerita dari kanca-kanca Brebes.">
  <Header />

  <main class="min-h-screen bg-slate-50 relative overflow-hidden pt-24 pb-20">
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">

      <div class="flex flex-col md:flex-row items-start justify-between gap-8 mb-12 md:mb-16">
        <div class="space-y-4 max-w-2xl text-left">
          <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border inline-flex items-center justify-center transition-all duration-300 shadow-sm bg-white text-blue-600 border-blue-100">
            Katalog Publikasi
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 tracking-tight leading-tight">
            Karya <span class="text-blue-600 italic font-serif font-light">Kanca</span>
          </h1>
          <p class="text-slate-600 text-sm md:text-base leading-relaxed">
            Kumpulan tulisan, opini, dan cerita dari kanca-kanca Brebesan. Baca gratis sepuasnya, <strong class="text-slate-900">wajib login</strong> kalau mau ikutan nulis.
          </p>
        </div>

        <div class="w-full md:w-auto shrink-0 pt-2 md:pt-10">
          <a href="/user/posts/create" class="flex items-center justify-center gap-2 bg-slate-900 text-white w-full px-8 py-4 rounded-2xl text-xs font-bold uppercase tracking-widest shadow-lg shadow-slate-900/20 hover:bg-blue-600 transition-all hover:-translate-y-1 active:scale-95 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-12 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Mulai Menulis
          </a>
        </div>
      </div>

      {posts.length === 0 ? (
        <div class="py-24 text-center border-2 border-dashed border-slate-300 rounded-[2rem] bg-white/50 px-4">
          <div class="text-5xl mb-4 opacity-50">📝</div>
          <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-2">Belum ada tulisan</h2>
          <p class="text-slate-500 text-sm md:text-base">Jadilah yang pertama nulis di Literasi Brebesan!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6 lg:gap-8">
          {posts.map((post) => (
            /* PENAMBAHAN CLASS `relative` DI SINI BIAR KLIKNYA GAK BOCOR */
            <article class="relative bg-white rounded-[2rem] shadow-sm border border-slate-200/60 overflow-hidden hover:shadow-2xl hover:shadow-blue-900/5 hover:-translate-y-1.5 transition-all duration-300 flex flex-col group">
              <div class="p-6 md:p-8 flex flex-col h-full">

                <div class="flex items-center justify-between text-[10px] font-bold text-slate-400 mb-4 uppercase tracking-wider">
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    {formatDate(post.updated_at)}
                  </span>
                  <span class="text-blue-600 bg-blue-50 px-2.5 py-1 rounded-lg truncate max-w-[120px] border border-blue-100/50">
                    {post.author_name || "Anonim"}
                  </span>
                </div>

                <h2 class="text-lg md:text-xl font-black text-slate-900 mb-3 leading-snug group-hover:text-blue-600 transition-colors line-clamp-2">
                  <a href={`/publikasi/${post.slug}`} class="before:absolute before:inset-0 outline-none">
                    {post.title}
                  </a>
                </h2>

                <p class="text-slate-500 text-sm mb-6 flex-grow line-clamp-3 leading-relaxed">
                  {truncateText(post.content)}
                </p>

                <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                  <span class="inline-flex items-center text-[10px] md:text-xs font-black uppercase tracking-widest text-slate-400 group-hover:text-blue-600 transition-colors">
                    Baca selengkapnya
                  </span>
                  <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white text-slate-400 transition-colors">
                    <svg class="w-4 h-4 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                  </div>
                </div>

              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>