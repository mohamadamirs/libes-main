---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { sql } from "../../lib/db";
import PublicationList from "../../components/main/PublicationList";
import CategoryScroll from "../../components/main/CategoryScroll";
import ScrollToTop from "../../components/ScrollToTop";

// Ambil kategori aktif dari query param
const activeCategoryId = Astro.url.searchParams.get("category");

// Ambil SEMUA KATEGORI dari database
const { rows: categories } = await sql`
  SELECT id, name, slug FROM categories ORDER BY name ASC
`;

// Ambil 9 postingan pertama untuk SSR awal
let initialPosts;
if (activeCategoryId) {
  const { rows } = await sql`
    SELECT
      p.title,
      p.content,
      p.slug,
      p.updated_at,
      p.user_id,
      pr.full_name as author_name,
      pr.instagram as author_instagram,
      pr.avatar_url as author_avatar,
      c.name as category_name
    FROM posts p
    LEFT JOIN profiles pr ON p.user_id = pr.id
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'published' AND p.category_id = ${activeCategoryId}
    ORDER BY p.updated_at DESC
    LIMIT 9
  `;
  initialPosts = rows;
} else {
  const { rows } = await sql`
    SELECT
      p.title,
      p.content,
      p.slug,
      p.updated_at,
      p.user_id,
      pr.full_name as author_name,
      pr.instagram as author_instagram,
      pr.avatar_url as author_avatar,
      c.name as category_name
    FROM posts p
    LEFT JOIN profiles pr ON p.user_id = pr.id
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.status = 'published'
    ORDER BY p.updated_at DESC
    LIMIT 9
  `;
  initialPosts = rows;
}
---

<Layout title="Publikasi | Literasi Brebesan" description="Kumpulan tulisan dan cerita dari teman-teman Brebes.">
  <Header />

  <main class="min-h-screen bg-slate-50 relative overflow-hidden pt-24 md:pt-32 pb-20">
    {/* Balik ke biru */}
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[30rem] h-[30rem] bg-blue-400/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">

      {/* Header */}
      <div class="flex flex-col md:flex-row items-start justify-between gap-6 mb-10 md:mb-14">
        <div class="space-y-3 max-w-2xl text-left">
          <span class="px-2.5 py-1 rounded-md text-[10px] md:text-[11px] font-black tracking-widest border inline-flex items-center justify-center transition-all shadow-sm bg-white text-blue-600 border-blue-200/60">
            Ruang Karya
          </span>
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-black text-slate-900 tracking-tight leading-tight">
            Ruang <span class="text-blue-600 font-bold lowercase tracking-normal">karya</span>
          </h1>
          <p class="text-slate-500 text-xs md:text-base leading-relaxed max-w-lg font-medium">
            Kumpulan tulisan, opini, dan cerita dari teman-teman. Baca gratis sepuasnya, <strong class="text-slate-700">wajib login</strong> untuk mulai berbagi.
          </p>
        </div>

        <div class="w-full md:w-auto shrink-0 md:mt-6">
          <a href="/user/posts/create" class="flex items-center justify-center gap-2 bg-slate-900 text-white w-full px-6 py-3.5 md:py-4 rounded-xl md:rounded-2xl text-[11px] md:text-xs font-black uppercase tracking-widest shadow-xl shadow-slate-900/10 hover:bg-blue-600 transition-all active:scale-95 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Tulis Sekarang
          </a>
        </div>
      </div>

      {/* Kategori dengan Custom Scrollbar React */}
      <CategoryScroll client:load>
        <a 
          href="/publikasi" 
          class={`shrink-0 px-5 py-2.5 rounded-full text-[10px] md:text-xs font-black uppercase tracking-widest transition-all border ${!activeCategoryId ? 'bg-blue-600 text-white border-blue-600 shadow-lg shadow-blue-200' : 'bg-white text-slate-500 border-slate-200 hover:border-blue-400'}`}
        >
          Semua
        </a>
        {categories.map((cat) => (
          <a 
            href={`/publikasi?category=${cat.id}`} 
            class={`shrink-0 px-5 py-2.5 rounded-full text-[10px] md:text-xs font-black uppercase tracking-widest transition-all border ${activeCategoryId === cat.id ? 'bg-blue-600 text-white border-blue-600 shadow-lg shadow-blue-200' : 'bg-white text-slate-500 border-slate-200 hover:border-blue-400'}`}
          >
            {cat.name}
          </a>
        ))}
      </CategoryScroll>

      {/* List Publikasi dengan Load More */}
      <PublicationList client:load initialPosts={initialPosts} categoryId={activeCategoryId} />
    </div>
  </main>

  <Footer />
  <ScrollToTop client:idle />
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
