---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { sql } from "../../lib/db";

// Narik postingan yang statusnya PUBLISHED
const { rows: posts } = await sql`
  SELECT
    p.title,
    p.content,
    p.slug,
    p.updated_at,
    pr.full_name as author_name
  FROM posts p
  LEFT JOIN profiles pr ON p.user_id = pr.id
  WHERE p.status = 'published'
  ORDER BY p.updated_at DESC
`;

const truncateText = (text: string | null, length = 120) => {
  if (!text) return "Tidak ada ringkasan...";
  return text.length > length ? text.substring(0, length) + "..." : text;
};

const formatDate = (date: any) => {
  if (!date) return "";
  return new Date(date).toLocaleDateString("id-ID", {
    year: "numeric", month: "short", day: "numeric",
  });
};
---

<Layout title="Publikasi | Literasi Brebesan" description="Kumpulan tulisan dan cerita dari teman-teman Brebes.">
  <Header />

  <main class="min-h-screen bg-slate-50 relative overflow-hidden pt-26 md:pt-28 pb-20">
    {/* Efek Latar Belakang */}
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[30rem] h-[30rem] bg-blue-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">

      {/* Bagian Header Katalog */}
      <div class="flex flex-col md:flex-row items-start justify-between gap-6 mb-10 md:mb-14">
        <div class="space-y-3 max-w-2xl text-left">
          <span class="px-2.5 py-1 rounded-md text-[11px] font-black uppercase tracking-widest border inline-flex items-center justify-center transition-all shadow-sm bg-white text-blue-600 border-blue-200/60">
            Katalog Publikasi
          </span>
          <h1 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight leading-tight">
            Karya <span class="text-blue-600 italic font-serif font-light">Literasi</span>
          </h1>
          <p class="text-slate-500 text-sm leading-relaxed max-w-lg">
            Kumpulan tulisan, opini, dan cerita dari teman-teman. Baca gratis sepuasnya, <strong class="text-slate-700">wajib login</strong> untuk menulis.
          </p>
        </div>

        <div class="w-full md:w-auto shrink-0 mt-2 md:mt-6">
          <a href="/user/posts/create" class="flex items-center justify-center gap-2 bg-slate-900 text-white w-full px-6 py-3.5 rounded-xl text-xs font-bold uppercase tracking-widest shadow-lg shadow-slate-900/10 hover:bg-blue-600 transition-all hover:-translate-y-0.5 active:scale-95 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:rotate-12 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Mulai Menulis
          </a>
        </div>
      </div>

      {/* Filter Kategori Minimalis */}
      <div class="flex items-center gap-2 overflow-x-auto pb-4 mb-6 md:mb-8 scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0">
        <button class="shrink-0 px-4 py-2 bg-slate-900 text-white text-[11px] md:text-xs font-bold rounded-lg shadow-sm transition-all">Semua</button>
        <button class="shrink-0 px-4 py-2 bg-white text-slate-500 hover:text-slate-900 hover:bg-slate-100 text-[11px] md:text-xs font-medium border border-slate-200 rounded-lg transition-all">Opini</button>
        <button class="shrink-0 px-4 py-2 bg-white text-slate-500 hover:text-slate-900 hover:bg-slate-100 text-[11px] md:text-xs font-medium border border-slate-200 rounded-lg transition-all">Sastra</button>
        <button class="shrink-0 px-4 py-2 bg-white text-slate-500 hover:text-slate-900 hover:bg-slate-100 text-[11px] md:text-xs font-medium border border-slate-200 rounded-lg transition-all">Resensi</button>
      </div>

      {posts.length === 0 ? (
        <div class="py-20 text-center border-2 border-dashed border-slate-200 rounded-3xl bg-white/50 px-4">
          <div class="text-4xl mb-3 opacity-40">📝</div>
          <h2 class="text-lg md:text-xl font-bold text-slate-900 mb-1">Belum ada tulisan</h2>
          <p class="text-slate-500 text-sm">Jadilah yang pertama menulis di Literasi Brebesan!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {posts.map((post) => (
            <article class="relative bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-xl hover:shadow-blue-900/5 hover:-translate-y-1 transition-all duration-300 flex flex-col group">
              {/* Padding dikurangi jadi p-5 agar lebih compact */}
              <div class="p-5 flex flex-col h-full">

                <h2 class="text-base md:text-lg font-black text-slate-900 mb-2 leading-snug group-hover:text-blue-600 transition-colors line-clamp-2">
                  <a href={`/publikasi/${post.slug}`} class="before:absolute before:inset-0 outline-none">
                    {post.title}
                  </a>
                </h2>

                <p class="text-slate-500 text-sm mb-4 flex-grow line-clamp-2 leading-relaxed">
                  {truncateText(post.content, 120)}
                </p>

                <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                  <div class="flex items-center gap-2 text-[11px] font-bold text-slate-400 uppercase tracking-wider truncate">
                    <span class="text-slate-600 truncate max-w-[100px]">{post.author_name || "Anonim"}</span>
                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                    <span>{formatDate(post.updated_at)}</span>
                  </div>

                  <div class="w-7 h-7 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-colors shrink-0">
                    <svg class="w-3 h-3 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
                  </div>
                </div>

              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>