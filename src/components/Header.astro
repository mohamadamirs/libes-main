---
import { Image } from 'astro:assets';
import logoImage from '../../public/literasi-brebesan.webp';
import ThemeToggle from './ThemeToggle';

// 1. Ambil data dari Middleware
const { user } = Astro.locals;

// Nav Config
const navLinks = [
  { name: "Beranda", href: "/" },
  { name: "Publikasi", href: "/publikasi" },
  { name: "Galeri", href: "/dokumentasi" },
];

// Helper inisial
const initial = user?.fullName?.charAt(0) || 'U';
---

<header class="relative z-50">
  <div class="fixed top-3 left-0 w-full z-[60] px-4 sm:px-6 lg:px-8 pointer-events-none">
    <div class="max-w-[1400px] mx-auto w-full pointer-events-auto">
      <nav
        id="main-nav"
        class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border border-slate-200/50 dark:border-slate-800/50 shadow-md rounded-2xl transition-all duration-300"
        aria-label="Navigasi Utama"
      >
        <div class="flex justify-between items-center h-14 md:h-16 px-4 sm:px-6 lg:px-8">
          <a href="/" class="flex items-center gap-3 group" aria-label="Beranda Literasi Brebesan">
            <Image
              src={logoImage}
              alt="Logo Literasi Brebesan"
              width={96} 
              height={96}
              quality="max"
              format="webp"
              loading="eager"
              class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-slate-100 dark:border-slate-800 shadow-sm object-cover"
            />
            <div class="flex flex-col leading-tight">
              <span class="font-black text-sm md:text-base uppercase text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors tracking-tight">Literasi</span>
              <span class="text-[11px] md:text-xs font-bold text-red-900 dark:text-red-400 uppercase tracking-wider">Brebesan</span>
            </div>
          </a>

          <ul class="hidden md:flex items-center gap-1.5 list-none">
            {navLinks.map((link) => (
              <li class={link.name === "Beranda" ? "group relative" : ""}>
                <a 
                  href={link.href} 
                  class="px-2.5 py-1.5 md:px-3 md:py-2 text-[11px] md:text-xs font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 rounded-xl transition-all uppercase tracking-wider flex items-center gap-1"
                >
                  {link.name}
                  {link.name === "Beranda" && (
                    <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                    </svg>
                  )}
                </a>
                
                {link.name === "Beranda" && (
                  <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 z-50">
                    <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 shadow-xl rounded-2xl p-2 min-w-[200px]">
                      <a href="/#tentang" class="block px-4 py-2 text-[10px] font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-all uppercase tracking-wider">
                        Tentang Kami
                      </a>
                      <a href="/#agenda" class="block px-4 py-2 text-[10px] font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-all uppercase tracking-wider">
                        Agenda
                      </a>
                      <a href="/#posts" class="block px-4 py-2 text-[10px] font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-all uppercase tracking-wider">
                        Tulisan
                      </a>
                      <a href="/#galeri" class="block px-4 py-2 text-[10px] font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-all uppercase tracking-wider">
                        Galeri
                      </a>
                    </div>
                  </div>
                )}
              </li>
            ))}
            <li class="h-5 w-px bg-slate-200 dark:bg-slate-800 mx-1.5 md:mx-2" role="separator"></li>
            
            {/* Theme Toggle */}
            <li class="flex items-center mr-1">
               <ThemeToggle client:load />
            </li>

            {user ? (
              <li class="flex items-center gap-1.5 md:gap-2">
                <a href="/profile" class="px-2.5 py-1.5 md:px-3 md:py-2 text-[11px] md:text-xs font-bold text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 rounded-xl transition-all uppercase tracking-wider">
                  Profil
                </a>
                <a href={user.role === 'admin' ? '/admin' : '/user'} class="px-2.5 py-1.5 md:px-3 md:py-2 text-[11px] md:text-xs font-bold text-slate-900 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800 rounded-xl transition-all uppercase tracking-wider flex items-center gap-1.5 md:gap-2">
                  <div class="w-5 h-5 md:w-6 md:h-6 rounded-md bg-blue-600 flex items-center justify-center text-white text-[11px] md:text-[11px] font-black uppercase overflow-hidden">
                    {user.avatarUrl ? (
                      <img src={user.avatarUrl} alt={user.fullName} class="w-full h-full object-cover" />
                    ) : (
                      initial
                    )}
                  </div>
                  Dashboard
                </a>
                <form action="/logout" method="POST" class="m-0">
                  <button type="submit" class="px-2.5 py-1.5 md:px-3 md:py-2 text-[11px] md:text-xs font-bold text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-900/20 rounded-xl transition-all uppercase tracking-wider cursor-pointer border-none bg-transparent">
                    Keluar
                  </button>
                </form>
              </li>
            ) : (
              <li>
                <a href="/login" class="bg-blue-600 text-white px-4 py-2 md:px-5 md:py-2.5 rounded-xl text-[11px] md:text-xs font-bold hover:bg-blue-700 hover:shadow-lg transition-all uppercase tracking-wider">
                  Login/Daftar
                </a>
              </li>
            )}
          </ul>

          <button
            id="menu-btn"
            class="md:hidden w-10 h-10 flex items-center justify-center text-slate-900 dark:text-white rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors pointer-events-auto relative group"
            aria-label="Menu"
            aria-expanded="false"
            aria-controls="drawer"
          >
            <div class="relative w-5 h-5 flex items-center justify-center">
              <span id="l1" class="absolute w-5 h-0.5 bg-slate-900 dark:bg-white rounded-full transition-all duration-300 -translate-y-1.5 group-aria-expanded:translate-y-0 group-aria-expanded:rotate-45"></span>
              <span id="l2" class="absolute w-5 h-0.5 bg-slate-900 dark:bg-white rounded-full transition-all duration-300 translate-y-1.5 group-aria-expanded:translate-y-0 group-aria-expanded:-rotate-45"></span>
            </div>
          </button>
        </div>
      </nav>
    </div>
  </div>

  <div id="overlay" class="fixed inset-0 bg-slate-950/30 z-[80] hidden opacity-0 transition-opacity duration-300 pointer-events-auto"></div>

  <aside
    id="drawer"
    class="fixed top-20 right-4 md:right-8 w-56 md:w-64 max-h-[calc(100vh-6rem)] bg-white dark:bg-slate-900 z-[90] translate-x-[150%] transition-transform duration-300 ease-in-out shadow-2xl rounded-3xl border border-slate-100 dark:border-slate-800 flex flex-col overflow-y-auto pointer-events-auto"
  >
    <div class="p-4 md:p-6">
      <span class="text-[11px] md:text-xs font-black text-slate-400 uppercase tracking-wider block mb-3">Menu Utama</span>
      <ul class="flex flex-col gap-1.5 md:gap-2 list-none">
        {navLinks.map((link) => (
          <li>
            {link.name === "Beranda" ? (
              <details class="group/details">
                <summary class="flex items-center justify-between px-3 py-2.5 md:px-4 md:py-3 text-xs md:text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-blue-600 dark:hover:text-blue-400 rounded-xl transition-all cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                  {link.name}
                  <svg class="w-4 h-4 transition-transform group-open/details:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                  </svg>
                </summary>
                <div class="ml-4 mt-1 flex flex-col gap-1 border-l-2 border-slate-100 dark:border-slate-800 pl-4 py-1">
                  <a href="/#tentang" class="px-3 py-2 text-[10px] font-bold text-slate-500 hover:text-blue-600 uppercase tracking-wider transition-colors">
                    Tentang Kami
                  </a>
                  <a href="/#agenda" class="px-3 py-2 text-[10px] font-bold text-slate-500 hover:text-blue-600 uppercase tracking-wider transition-colors">
                    Agenda
                  </a>
                  <a href="/#posts" class="px-3 py-2 text-[10px] font-bold text-slate-500 hover:text-blue-600 uppercase tracking-wider transition-colors">
                    Tulisan
                  </a>
                  <a href="/#galeri" class="px-3 py-2 text-[10px] font-bold text-slate-500 hover:text-blue-600 uppercase tracking-wider transition-colors">
                    Galeri
                  </a>
                </div>
              </details>
            ) : (
              <a href={link.href} class="block px-3 py-2.5 md:px-4 md:py-3 text-xs md:text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-blue-50 dark:hover:bg-slate-800 hover:text-blue-600 dark:hover:text-blue-400 rounded-xl transition-all">
                {link.name}
              </a>
            )}
          </li>
        ))}
      </ul>

      <div class="mt-4 md:mt-6 pt-4 md:pt-6 border-t border-slate-100 dark:border-slate-800 flex flex-col gap-3 md:gap-4">
        {user ? (
          <div class="space-y-2 md:space-y-3">
            <div class="flex items-center gap-3 px-3 py-2.5 md:px-4 md:py-3 bg-slate-50 dark:bg-slate-800 rounded-xl">
              <div class="w-7 h-7 md:w-8 md:h-8 rounded-md bg-blue-600 flex items-center justify-center text-white text-[11px] md:text-sm font-black uppercase shrink-0 overflow-hidden">
                {user.avatarUrl ? (
                  <img src={user.avatarUrl} alt={user.fullName} class="w-full h-full object-cover" />
                ) : (
                  initial
                )}
              </div>
              <div class="flex flex-col min-w-0">
                <span class="text-xs md:text-sm font-bold text-slate-900 dark:text-white truncate uppercase tracking-tight leading-none">{user.fullName?.split(' ')[0] || 'User'}</span>
                <span class="text-[11px] md:text-xs text-blue-600 dark:text-blue-400 font-black uppercase tracking-wider leading-none mt-1">{user.role}</span>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-2">
              <a href="/profile" class="block text-center py-2.5 md:py-3 text-xs md:text-sm font-black text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-800 rounded-xl uppercase tracking-wider hover:bg-indigo-50 dark:hover:bg-indigo-900/20 hover:text-indigo-600 transition-all">Profil</a>
              <a href={user.role === 'admin' ? '/admin' : '/user'} class="block text-center py-2.5 md:py-3 text-xs md:text-sm font-black text-slate-900 dark:text-white bg-slate-100 dark:bg-slate-800 rounded-xl uppercase tracking-wider hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 transition-all">Dashboard</a>
            </div>
            <form action="/logout" method="POST" class="w-full m-0">
              <button type="submit" class="w-full text-center py-2.5 md:py-3 text-xs md:text-sm font-black text-rose-600 dark:text-rose-400 uppercase tracking-wider cursor-pointer bg-rose-50 dark:bg-rose-900/20 rounded-xl border-none">Keluar Akun</button>
            </form>
          </div>
        ) : (
          <div class="flex flex-col gap-2">
            <ThemeToggle client:load />
            <a href="/login" class="flex items-center justify-center bg-slate-900 dark:bg-blue-600 text-white py-2.5 md:py-3 rounded-xl text-xs md:text-sm font-bold uppercase tracking-wider shadow-lg hover:bg-slate-800 transition-all">Login/Daftar</a>
          </div>
        )}
      </div>
    </div>
  </aside>
</header>

<script>
  function initHeader() {
    const btn = document.getElementById('menu-btn');
    const drawer = document.getElementById('drawer');
    const overlay = document.getElementById('overlay');
    const l1 = document.getElementById('l1');
    const l2 = document.getElementById('l2');
    let isOpen = false;

    function toggleMenu(force) {
      isOpen = force !== undefined ? force : !isOpen;

      btn?.setAttribute('aria-expanded', String(isOpen));

      if (isOpen) {
        overlay?.classList.remove('hidden');
        setTimeout(() => overlay?.classList.add('opacity-100'), 10);
        drawer?.classList.remove('translate-x-[150%]');
      } else {
        overlay?.classList.remove('opacity-100');
        setTimeout(() => overlay?.classList.add('hidden'), 300);
        drawer?.classList.add('translate-x-[150%]');
      }
    }

    btn?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    overlay?.addEventListener('click', () => toggleMenu(false));

    document.querySelectorAll('#drawer a, #drawer button').forEach(el => {
      el.addEventListener('click', () => toggleMenu(false));
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>