---
import FeaturedGallery from "./FeaturedGallery";
---
<section id="galeri" class="py-16 md:py-24 bg-slate-950 text-white overflow-hidden relative text-left">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="mb-8 md:mb-16 space-y-3 md:space-y-4 text-left">
      <div class="inline-flex items-center gap-2 bg-white/5 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-white/10 mb-2">
        <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-blue-500 animate-pulse"></span>
        <span class="text-[11px] md:text-xs font-black uppercase tracking-widest text-white/80 leading-none">Dokumentasi</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black tracking-tight uppercase leading-none">
        Merawat <span class="text-blue-500 italic font-serif font-light lowercase tracking-normal">momen</span>
      </h2>
      <p class="mt-3 md:mt-4 text-slate-400 font-medium max-w-xl text-sm md:text-lg leading-relaxed">
        Arsip visual perjalanan dan perjumpaan kita dalam merawat nalar.
      </p>
    </div>
    
    <FeaturedGallery client:visible />

    <div class="mt-8 text-left">
      <a href="/dokumentasi" class="inline-flex items-center gap-2 md:gap-3 bg-white text-slate-950 px-6 py-3.5 md:px-8 md:py-4 rounded-xl md:rounded-2xl font-bold text-[11px] md:text-sm uppercase tracking-widest hover:bg-blue-500 hover:text-white transition-all shadow-lg shadow-black/10">Galeri Penuh →</a>
    </div>
  </div>
</section>
