---
import { sql } from "../../lib/db";

const { rows: posts } = await sql`
  SELECT 
    p.title, 
    p.slug, 
    p.content, 
    p.updated_at, 
    p.user_id,
    pr.full_name as author_name,
    pr.avatar_url as author_avatar
  FROM posts p
  LEFT JOIN profiles pr ON p.user_id = pr.id
  WHERE p.status = 'published'
  ORDER BY p.updated_at DESC
  LIMIT 3
`;

const stripHtml = (html: string) => {
  if (!html) return "";
  return html.replace(/<[^>]*>?/gm, ' ').replace(/\s+/g, ' ').trim();
};

const truncateText = (text: string | null, length = 100) => {
  if (!text) return "";
  const clean = stripHtml(text);
  if (clean.length <= length) return clean;
  return clean.substring(0, length).trim() + "...";
};

const truncateTitle = (text: string | null, length = 55) => {
  if (!text) return "";
  if (text.length <= length) return text;
  return text.substring(0, length).trim() + "...";
};
---

<section id="posts" class="py-20 md:py-32 bg-slate-50 relative overflow-hidden border-t border-slate-100">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-12 md:mb-20 text-left">
      <div class="inline-flex items-center gap-2 bg-blue-50 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-blue-100 mb-4 md:mb-6 text-left">
        <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-blue-600"></span>
        <span class="text-[11px] md:text-xs font-black uppercase tracking-widest text-blue-700 leading-none">Tulisan Terbaru</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black text-slate-900 tracking-tight leading-tight">
        Ruang <span class="text-blue-600 italic font-serif font-light lowercase tracking-normal">suara</span>
      </h2>
      <p class="mt-3 md:mt-4 text-slate-500 font-medium max-w-xl text-sm md:text-lg leading-relaxed">
        Gagasan dan cerita dari teman-teman melalui tulisan.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      {posts.map((post) => (
        <article class="group relative flex flex-col bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-purple-900/5 hover:-translate-y-2 transition-all duration-500">
          <div class="flex-1">
            <h3 class="text-base md:text-xl font-black text-slate-900 mb-3 leading-tight group-hover:text-blue-600 transition-colors tracking-tight line-clamp-2 break-words w-full min-h-[3rem] md:min-h-[3.5rem]" title={post.title}>
              <a href={`/publikasi/${post.slug}`} class="before:absolute before:inset-0 outline-none">
                {truncateTitle(post.title, 55)}
              </a>
            </h3>
            <p class="text-slate-500 text-xs md:text-sm leading-relaxed mb-6 line-clamp-2 font-medium break-words flex-grow">
              {truncateText(post.content, 90)}
            </p>
          </div>

          <div class="pt-5 border-t border-slate-100 flex items-center justify-between relative z-20">
            <div class="flex items-center gap-3">
              <a href={`/p/${post.user_id}`} class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-black text-[10px] md:text-xs uppercase overflow-hidden border-2 border-white shadow-sm hover:scale-110 transition-transform">
                {post.author_avatar ? (
                  <img src={post.author_avatar} alt={post.author_name} class="w-full h-full object-cover" />
                ) : (
                  post.author_name?.charAt(0) || 'U'
                )}
              </a>
              <div class="flex flex-col">
                <a href={`/p/${post.user_id}`} class="text-[10px] md:text-[11px] font-black text-slate-900 tracking-wider hover:text-blue-600 transition-colors">{post.author_name || "Anonim"}</a>
                <span class="text-[9px] md:text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">Penulis</span>
              </div>
            </div>
            <div class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white group-hover:border-blue-600 transition-all shadow-sm">
              <svg class="w-3.5 h-3.5 md:w-4 md:h-4 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-left">
      <a href="/publikasi" class="inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-widest text-slate-400 hover:text-blue-600 transition-colors">
        Lihat Semua Tulisan
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>
