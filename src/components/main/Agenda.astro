---
import AgendaIsland from './AgendaIsland';
---

<section id="agenda" class="py-16 md:py-24 bg-white relative overflow-hidden border-t border-slate-50 scroll-mt-20 md:scroll-mt-28">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- Section Header -->
    <div class="mb-8 md:mb-16 text-left">
      <div class="inline-flex items-center gap-2 bg-amber-50 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-amber-100 mb-4 md:mb-6">
        <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-amber-500 animate-pulse"></span>
        <span class="text-[11px] md:text-xs font-black uppercase tracking-widest text-amber-700 leading-none">Agenda Terdekat</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black text-slate-900 tracking-tight uppercase leading-tight">
        Ruang <span class="text-blue-600 font-bold lowercase tracking-normal">temu</span>
      </h2>
      <p class="mt-3 md:mt-4 text-slate-500 font-medium max-w-xl text-sm md:text-lg leading-relaxed">
        Merawat nalar lewat diskusi dan aksi nyata bersama kawan-kolektif di Brebes.
      </p>
    </div>

    <!-- Agenda Card Island -->
    <AgendaIsland client:visible />

  </div>
</section>
