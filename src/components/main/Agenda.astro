---
import { sql } from '../../lib/db';

/* ====================================================================
   1. TRIK LAZY EVALUATION (AUTO-SWAP STATUS)
   Cek apakah ada agenda 'scheduled' yang waktunya sudah tiba.
   ==================================================================== */
const { rows: readyToPublish } = await sql`
  SELECT id FROM agendas
  WHERE status = 'scheduled'
    AND publish_at <= CURRENT_TIMESTAMP
  ORDER BY publish_at ASC
  LIMIT 1
`;

// Jika ada agenda yang antre dan sudah waktunya rilis...
if (readyToPublish.length > 0) {
  const newAgendaId = readyToPublish[0].id;

  // A. Lengserkan semua agenda yang saat ini 'published' menjadi 'draft'
  await sql`UPDATE agendas SET status = 'draft' WHERE status = 'published'`;

  // B. Naikkan tahta agenda yang baru menjadi 'published', dan bersihkan jadwalnya
  await sql`UPDATE agendas SET status = 'published', publish_at = NULL WHERE id = ${newAgendaId}`;
}

/* ====================================================================
   2. QUERY UTAMA SEPERTI BIASA
   Sekarang database dijamin bersih, hanya ada maksimal 1 yang published
   ==================================================================== */
const { rows } = await sql`
  SELECT * FROM agendas
  WHERE event_date >= CURRENT_DATE
    AND status = 'published'
  ORDER BY event_date ASC
  LIMIT 1
`;

const agenda = rows[0];

// Helper format tanggal
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('id-ID', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  });
};
---

<section id="agenda" class="py-16 px-4 bg-slate-50/50 text-left">
  <div class="container mx-auto max-w-7xl">

    <div class="flex flex-col md:flex-row items-start justify-between mb-12 gap-4 text-left">
      <div class="space-y-3 text-left">
        <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border inline-flex items-center justify-center transition-all duration-300 shadow-sm bg-amber-500 text-white border-amber-600">
          {agenda ? "Kegiatan Terdekat" : "Kegiatan"}
        </span>
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight text-left">
          Agenda <span class="text-blue-600 italic font-serif font-light">{agenda ? "Mendatang" : "Rutin"}</span>
        </h2>
      </div>
      <div id="label-agenda" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] pt-1 text-left md:text-right">
        {agenda ? "Jangan Sampai Terlewat!" : "Memuat Tanggal..."}
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch text-left">

      <div class="lg:col-span-5 aspect-video lg:aspect-auto bg-slate-200 rounded-3xl overflow-hidden border border-slate-300 shadow-lg">
        {agenda && agenda.image_url ? (
          <img src={agenda.image_url} alt={agenda.title} class="w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full flex flex-col items-center justify-center text-slate-400 text-center p-6 bg-gradient-to-br from-slate-100 to-slate-200">
            <p class="font-bold text-[9px] uppercase tracking-[0.3em]">Poster Kegiatan</p>
          </div>
        )}
      </div>

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6 lg:p-6 text-left">

        {agenda ? (
          /* JIKA ADA AGENDA TAYANG */
          <>
            <div class="space-y-3 text-left">
              <h3 class="text-2xl font-bold text-slate-900 leading-tight">{agenda.title}</h3>
              <p class="text-sm md:text-lg text-slate-600 leading-relaxed max-w-2xl">{agenda.description}</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl text-left">
              <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
                <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Waktu</p>
                <p class="text-sm font-bold text-slate-900">{formatDate(agenda.event_date)}</p>
                <p class="text-[10px] text-slate-500 font-medium">{agenda.event_time} WIB - Selesai</p>
              </div>
              <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
                <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Lokasi</p>
                <p class="text-sm font-bold text-slate-900">{agenda.location}</p>
                <p class="text-[10px] text-slate-500 font-medium">Detail di Grup WA</p>
              </div>
            </div>

            <a href={agenda.wa_link} target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-slate-900 transition-all shadow-lg shadow-blue-200 w-full sm:w-auto text-sm">
              RSVP via WhatsApp
            </a>
          </>
        ) : (
          /* DEFAULT FALLBACK */
          <>
            <div class="space-y-3 text-left">
              <h3 class="text-2xl font-bold text-slate-900 leading-tight">Diskusi & Nongkrong Mingguan</h3>
              <p class="text-sm md:text-lg text-slate-600 leading-relaxed max-w-2xl">Kumpul bareng teman-teman kolektif buat bahas isu terkini, bedah buku ringan, atau sekadar ngopi. Terbuka untuk umum!</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl text-left">
              <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
                <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Waktu</p>
                <p class="text-sm font-bold text-slate-900">Setiap Minggu</p>
                <p class="text-[10px] text-slate-500 font-medium">15:00 WIB - Selesai</p>
              </div>
              <div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-left">
                <p class="text-[8px] font-black text-blue-600 uppercase tracking-widest mb-1">Lokasi</p>
                <p class="text-sm font-bold text-slate-900">Kedai Kopi Sekitar</p>
                <p class="text-[10px] text-slate-500 font-medium">Brebes (Lokasi Update di WA)</p>
              </div>
            </div>

            <a href="https://wa.me/628993986415" target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-slate-900 transition-all shadow-lg shadow-blue-200 w-full sm:w-auto text-sm">
              RSVP via WhatsApp
            </a>
          </>
        )}
      </div>
    </div>
  </div>
</section>

{!agenda && (
  <script>
    document.addEventListener('astro:page-load', () => {
      const labelAgenda = document.getElementById('label-agenda');
      if (!labelAgenda) return;

      const today = new Date();
      const dayOfWeek = today.getDay();
      const nextSunday = new Date(today);
      nextSunday.setDate(today.getDate() + (7 - dayOfWeek));

      const formatter = new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
      labelAgenda.textContent = `Agenda Minggu Ini: ${formatter.format(nextSunday)}`;
    });
  </script>
)}