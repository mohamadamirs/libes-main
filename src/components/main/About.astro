---
import CopyAccount from "./CopyAccount";
---

<section id="tentang" class="py-16 md:py-24 bg-white relative overflow-hidden border-t border-slate-50 scroll-mt-20 md:scroll-mt-28">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- Section Header -->
    <div class="mb-10 md:mb-16 text-left">
      <div class="inline-flex items-center gap-2 bg-blue-50 px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-blue-100 mb-4 md:mb-6">
        <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-blue-600 animate-pulse"></span>
        <span class="text-[11px] md:text-xs font-black uppercase tracking-wider text-blue-700 leading-none">Visi & Misi</span>
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black text-slate-900 uppercase leading-tight">
        Arah <span class="text-blue-600 font-bold lowercase tracking-normal">Gerak Kita</span>
      </h2>
      <p class="mt-3 md:mt-4 text-slate-500 font-medium max-w-xl text-sm md:text-lg leading-relaxed">
        Menjadi garda depan dalam pengembangan budaya literasi yang kreatif dan inklusif di Brebes.
      </p>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-start">
      
      <!-- Kolom Kiri: Visi Misi & Slogan (Span 7) -->
      <div class="lg:col-span-7 space-y-8 md:space-y-10">
        
        <div id="visi-misi" class="bg-slate-50 rounded-[2rem] p-6 md:p-8 border border-slate-100 space-y-6 md:space-y-8 hover:shadow-xl hover:shadow-blue-900/5 transition-all duration-500 relative overflow-hidden">
          
          <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 bg-blue-500/5 rounded-full blur-2xl"></div>

          <div class="relative z-10 space-y-3 md:space-y-4">
            <h3 class="text-lg md:text-xl font-black text-slate-900  flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shadow-sm">V</span>
              Visi
            </h3>
            <p class="text-slate-600 font-bold text-sm md:text-lg leading-relaxed pl-11">
              Menjadi garda depan dalam pengembangan budaya literasi yang kreatif dan inklusif serta berwawasan sosial.
            </p>
          </div>

          <div class="h-px bg-slate-200/60 w-full relative z-10"></div>

          <div class="relative z-10 space-y-4 md:space-y-5">
            <h3 class="text-lg md:text-xl font-black text-slate-900  flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shadow-sm">M</span>
              Misi
            </h3>
            <ul class="space-y-4 md:space-y-6 list-none p-0 m-0 pl-11">
              {[
                { n: "1", t: "Menumbuhkan minat baca lewat kegiatan literasi yang seru and inklusif." },
                { n: "2", t: "Mendorong diskusi sehat untuk melatih berpikir kritis and kreatif." },
                { n: "3", t: "Mewujudkan ruang untuk tumbuh bersama masyarakat and berkontribusi melalui gerakan sosial sebagai kontribusi nyata untuk masyarakat luas." }
              ].map(m => (
                <li class="flex items-start gap-4 text-slate-600 font-medium text-sm md:text-base leading-relaxed">
                  <span class="flex items-center justify-center w-6 h-6 rounded-lg bg-blue-600 text-white text-[10px] font-black shrink-0 mt-0.5">{m.n}</span>
                  {m.t}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Slogan Section -->
        <div class="flex flex-wrap gap-3">
           {['#Literasiberdampak', '#LiterasiUntukSemua', '#MembacaBerdayaBergerakNyata'].map(s => (
             <span class="px-5 py-2.5 bg-white border border-slate-200 rounded-full text-[10px] md:text-xs font-black text-blue-600 uppercase tracking-wider shadow-sm hover:shadow-md transition-all">
               {s}
             </span>
           ))}
        </div>

      </div>

      <!-- Kolom Kanan: Info Tambahan (Span 5) -->
      <div class="lg:col-span-5 space-y-6 md:space-y-8">
        
        <!-- Perencanaan Kedepan Card -->
        <div id="rencana" class="bg-slate-900 rounded-[2rem] p-6 md:p-8 text-white relative overflow-hidden shadow-2xl scroll-mt-32">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-600/20 rounded-full blur-3xl"></div>
          <h3 class="text-lg md:text-xl font-black  mb-6 flex items-center gap-3">
            <span class="w-2 h-6 bg-blue-600 rounded-full"></span>
            Perencanaan Kedepan
          </h3>
          <ul class="grid grid-cols-1 gap-3">
            {[
              "Lapak Buku", "Nderes Buku", "Anjangsana", 
              "Kolaborasi Antar Komunitas", "Go to School", "Musikalisasi Puisi"
            ].map(plan => (
              <li class="flex items-center gap-3 text-xs md:text-sm font-bold text-slate-300 group cursor-default">
                <svg class="w-4 h-4 text-blue-500 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                {plan}
              </li>
            ))}
          </ul>
        </div>

        <!-- Pembayaran Kas Card -->
        <div id="kas" class="bg-white border-2 border-dashed border-slate-200 rounded-[2rem] p-6 md:p-8 shadow-sm scroll-mt-32">
          <h3 class="text-sm md:text-base font-black text-slate-900 uppercase tracking-wider mb-4">Kas Komunitas</h3>
          
          <CopyAccount 
            client:load 
            accountNumber="105018103098" 
            accountName="An. Purwanti / Jago" 
          />

          <div class="space-y-3">
             <p class="text-[10px] font-black uppercase text-slate-500 tracking-wider">Note:</p>
             <div class="flex items-start gap-2">
               <span class="w-1.5 h-1.5 rounded-full bg-red-500 mt-1.5 shrink-0"></span>
               <p class="text-xs font-bold text-slate-600 leading-tight">Wajib untuk pengurus setiap pertemuan</p>
             </div>
             <div class="flex items-start gap-2">
               <span class="w-1.5 h-1.5 rounded-full bg-green-500 mt-1.5 shrink-0"></span>
               <p class="text-xs font-bold text-slate-600 leading-tight">Sunah (sukarela) untuk anggota</p>
             </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>
