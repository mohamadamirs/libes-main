---
const stats = [
  { 
    label: "Kawan Bergabung", 
    value: "100+", 
    color: "blue",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`
  },
  { 
    label: "Koleksi Buku", 
    value: "70+", 
    color: "indigo",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`
  },
  { 
    label: "Diskusi Rutin", 
    value: "50+", 
    color: "amber",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`
  },
  { 
    label: "Aksi Nyata", 
    value: "10+", 
    color: "rose",
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  }
];

const colorClasses = {
  blue: "text-blue-600 bg-blue-50 border-blue-100",
  indigo: "text-indigo-600 bg-indigo-50 border-indigo-100",
  amber: "text-amber-600 bg-amber-50 border-amber-100",
  rose: "text-rose-600 bg-rose-50 border-rose-100"
};
---

<section class="py-12 md:py-20 bg-white relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
      {stats.map((item) => (
        <div class="group relative bg-white p-6 md:p-10 rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-slate-200 transition-all duration-500 hover:-translate-y-2 flex flex-col items-center text-center">
          
          <!-- Icon Circle -->
          <div class={`w-12 h-12 md:w-16 md:h-16 rounded-2xl flex items-center justify-center mb-6 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3 ${colorClasses[item.color as keyof typeof colorClasses]}`}>
            <Fragment set:html={item.icon} />
          </div>

          <!-- Value -->
          <span class="text-3xl md:text-5xl font-black text-slate-900 mb-2 tracking-tight group-hover:text-blue-600 transition-colors">
            {item.value}
          </span>

          <!-- Label -->
          <span class="text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-slate-400 leading-none">
            {item.label}
          </span>

          <!-- Decorative element -->
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-12 h-1 bg-slate-100 rounded-full transition-all duration-500 group-hover:w-24 group-hover:bg-blue-600 opacity-0 group-hover:opacity-100 -mb-0.5"></div>
        </div>
      ))}
    </div>
  </div>
  
  <!-- Background Decorations -->
  <div class="absolute top-1/2 left-0 -translate-y-1/2 -translate-x-1/2 w-64 h-64 bg-blue-50 rounded-full blur-3xl opacity-50 -z-10"></div>
  <div class="absolute top-1/2 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-indigo-50 rounded-full blur-3xl opacity-50 -z-10"></div>
</section>