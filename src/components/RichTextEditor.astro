---
interface Props {
  name: string;
  value?: string;
  placeholder?: string;
}

const { name, value = "", placeholder = "Tulis ceritamu di sini..." } = Astro.props;
---

<div class="rich-text-wrapper mb-6">
  <div class="bg-white border border-slate-200 rounded-[1.5rem] md:rounded-[2rem] overflow-hidden focus-within:ring-4 focus-within:ring-blue-50 transition-all">
    <div class="quill-editor min-h-[250px] md:min-h-[300px] text-slate-700 font-medium" data-placeholder={placeholder} data-content={value}></div>
  </div>
  <input type="hidden" name={name} class="quill-hidden-input" value={value} />
</div>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<style is:global>
  /* Menyesuaikan style Quill agar senada dengan form kita */
  .ql-toolbar.ql-snow {
    border: none !important;
    border-bottom: 1px solid #e2e8f0 !important;
    padding: 0.5rem 1rem !important;
    background: #f8fafc;
  }
  @media (min-width: 768px) {
    .ql-toolbar.ql-snow {
      padding: 1rem 1.5rem !important;
    }
  }
  .ql-container.ql-snow {
    border: none !important;
    font-size: 0.9rem;
    font-family: inherit;
  }
  @media (min-width: 768px) {
    .ql-container.ql-snow {
      font-size: 1rem;
    }
  }
  .ql-editor {
    padding: 1rem !important;
    min-height: 250px;
    line-height: 1.6;
  }
  @media (min-width: 768px) {
    .ql-editor {
      padding: 1.5rem !important;
      min-height: 300px;
      line-height: 1.8;
    }
  }
  .ql-editor.ql-blank::before {
    left: 1rem !important;
    color: #cbd5e1;
    font-style: italic;
  }
  @media (min-width: 768px) {
    .ql-editor.ql-blank::before {
      left: 1.5rem !important;
    }
  }
  .ql-editor h1, .ql-editor h2, .ql-editor h3 {
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  .ql-editor a {
    color: #2563eb;
  }
</style>

<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const wrappers = document.querySelectorAll('.rich-text-wrapper');
    
    wrappers.forEach(wrapper => {
      const editorEl = wrapper.querySelector('.quill-editor');
      const hiddenInput = wrapper.querySelector('.quill-hidden-input');
      
      if (editorEl && !wrapper.querySelector('.ql-toolbar')) {
        const placeholder = editorEl.getAttribute('data-placeholder');
        const initialContent = editorEl.getAttribute('data-content');
        
        const quill = new Quill(editorEl, {
          theme: 'snow',
          placeholder: placeholder,
          modules: {
            toolbar: {
              container: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                ['blockquote', 'code-block'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image'],
                ['clean']
              ],
              handlers: {
                image: function() {
                  const input = document.createElement('input');
                  input.setAttribute('type', 'file');
                  input.setAttribute('accept', 'image/*');
                  input.click();

                  input.onchange = async () => {
                    const file = input.files[0];
                    if (file) {
                      const range = this.quill.getSelection();
                      
                      // Beri placeholder loading (opsional, tapi bagus untuk UX)
                      this.quill.insertText(range.index, 'Mengunggah gambar...', 'italic', true);
                      
                      const formData = new FormData();
                      formData.append('image', file);

                      try {
                        const res = await fetch('/api/upload-image', {
                          method: 'POST',
                          body: formData
                        });
                        const data = await res.json();
                        
                        // Hapus teks loading
                        this.quill.deleteText(range.index, 20);

                        if (res.ok && data.url) {
                          // Masukkan gambar beneran
                          this.quill.insertEmbed(range.index, 'image', data.url);
                        } else {
                          alert('Gagal mengunggah gambar: ' + (data.error || 'Unknown error'));
                        }
                      } catch (error) {
                        this.quill.deleteText(range.index, 20);
                        alert('Terjadi kesalahan saat mengunggah.');
                        console.error(error);
                      }
                    }
                  };
                }
              }
            }
          }
        });
        
        // Isi konten awal jika sedang mode Edit
        if (initialContent) {
          const delta = quill.clipboard.convert(initialContent);
          quill.setContents(delta, 'silent');
        }
        
        // Simpan ke hidden input setiap form disubmit
        const form = wrapper.closest('form');
        if (form) {
          form.addEventListener('submit', () => {
            const html = quill.root.innerHTML;
            hiddenInput.value = html === '<p><br></p>' ? '' : html;
          });
        }
      }
    });
  });
</script>