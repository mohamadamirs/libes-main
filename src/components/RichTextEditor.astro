---
import RichTextEditorReact from "./Editor/RichTextEditor";

interface Props {
  name: string;
  value?: string;
  placeholder?: string;
}

const { name, value = "", placeholder = "Tulis ceritamu di sini..." } = Astro.props;
---

<div class="rich-text-wrapper mb-6">
  {/* Komponen React/Preact untuk Tab Mode */}
  <RichTextEditorReact client:load name={name} value={value} placeholder={placeholder} />
</div>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<style is:global>
  /* Menyesuaikan style Quill agar senada dengan desain kita */
  .ql-toolbar.ql-snow {
    border: 1px solid #dbeafe !important; /* blue-100 */
    border-top: none !important;
    padding: 0.75rem 1rem !important;
    background: rgba(239, 246, 255, 0.95) !important; /* blue-50 */
    backdrop-filter: blur(12px) !important;
    position: sticky !important;
    top: 118px; /* Menyesuaikan: Header(68px) + Tabs(approx 50px) */
    z-index: 40;
    border-radius: 0 0 1rem 1rem !important;
    box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.05);
    transition: all 0.3s ease;
  }
  @media (min-width: 768px) {
    .ql-toolbar.ql-snow {
      top: 136px; /* Menyesuaikan: Header(80px) + Tabs(approx 56px) */
      padding: 1rem 1.5rem !important;
      border-radius: 0 0 2rem 2rem !important;
    }
  }
  .ql-container.ql-snow {
    border: none !important;
    font-family: inherit;
  }
  .ql-editor {
    padding: 2rem !important; /* Disamakan dengan p-8 preview */
    min-height: 500px;
    font-size: 1rem;
    line-height: 1.8;
    color: #334155;
  }
  @media (min-width: 768px) {
    .ql-editor {
      padding: 3rem !important; /* Disamakan dengan md:p-12 preview */
    }
  }
  .ql-editor h1, .ql-editor h2, .ql-editor h3 {
    font-weight: 900 !important;
    color: #0f172a !important;
    letter-spacing: -0.02em !important;
    margin-top: 1.5em !important;
    margin-bottom: 0.5em !important;
    line-height: 1.2 !important;
  }
  .ql-editor a {
    color: #2563eb !important;
    text-decoration: underline !important;
    text-underline-offset: 4px;
  }
  .ql-editor img {
    border-radius: 1.5rem !important;
    box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1);
    margin: 2rem 0 !important;
  }
  .ql-editor blockquote {
    border-left: 4px solid #2563eb !important;
    background: rgba(239, 246, 255, 0.5) !important;
    padding: 1.5rem 2rem !important;
    border-radius: 0 1.5rem 1.5rem 0 !important;
    font-style: italic !important;
  }
</style>

<script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
